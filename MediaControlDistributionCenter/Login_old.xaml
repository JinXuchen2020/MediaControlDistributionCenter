<Window x:Class="MediaControlDistributionCenter.Views.Login_old"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:CustomControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
        WindowStyle="ThreeDBorderWindow"
        ResizeMode="CanMinimize"
        WindowState="Maximized"
        mc:Ignorable="d"
        Title="统一媒体管理平台登录" >
    <Window.Resources>

        <Style TargetType="Button" x:Key="lanButton">
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <!-- 纯文本按钮样式 -->
        <Style TargetType="Button" x:Key="TextButtonStyle">
            <!-- 设置按钮本身的外观，去除背景和边框 -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>

            <!-- 当按钮被点击时，改变文本颜色 -->
            <Style.Triggers>
                <!-- 点击时变色 -->
                <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Foreground" Value="Red"/>
                </DataTrigger>
                <!-- 鼠标悬停时，改变文本颜色 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="Green"/>
                </Trigger>
                <!-- 正常状态下，使用默认文本颜色 -->
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <!-- 标题 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <!--<Border   Background="AliceBlue"/>-->
        <Grid x:Name="top" Grid.Row="0">
            <Border Background="#545454"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="仪表盘" Width="100" Height="50" Style="{StaticResource TextButtonStyle}"/>
                <Button Content="设备管理" Width="100" Height="50" Style="{StaticResource TextButtonStyle}"/>
                <Button Content="模板库" Width="100" Height="50" Style="{StaticResource TextButtonStyle}"/>
                <Button Content="设定" Width="100" Height="50" Style="{StaticResource TextButtonStyle}"/>
            </StackPanel>
            <CustomControls:RoundRectButton x:Name="LanguageButton" HorizontalAlignment="Right" 
                                            Margin="0,0,5,0"
                                            Background="WhiteSmoke" 
                                            CornerRadius="2"
                                            BorderWidth="0"
                                            IconSource="/Assets/地球.png"
                                            Width="150"
                                            Height="50"
                                            Click="SwitchLanguage_Click"
                                            Content="{DynamicResource LanguageKey_Code_SwitchLanguage}" />

            <Popup x:Name="LanguagePopup" Placement="Bottom" StaysOpen="False" PlacementTarget="{Binding ElementName=LanguageButton}">
                <StackPanel Background="WhiteSmoke" Width="150">
                    <Button x:Name="ChineseButton" Style="{StaticResource lanButton}" Content="中文" Click="ChangeLanguage"/>
                    <Button x:Name="EnglishButton" Style="{StaticResource lanButton}" Content="英语" Click="ChangeLanguage"/>
                    <Button x:Name="JapaneseButton" Style="{StaticResource lanButton}" Content="日语" Click="ChangeLanguage"/>
                    <Button x:Name="KoreanButton" Style="{StaticResource lanButton}" Content="韩语" Click="ChangeLanguage"/>
                </StackPanel>
            </Popup>
        </Grid>
        <Border Grid.Row="1" Grid.RowSpan="3"  Background="#F1F5FB"/>
        <TextBlock Background="Transparent" Margin="0,120,0,0" Grid.Row="1"
                   Text="{DynamicResource LanguageKey_Code_SysloginTitle}"
                   FontSize="45"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"/>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" HorizontalAlignment="Right" Margin="0,0,50,0" Source="/Assets/logo.png" Width="240" Height="80"/>
            <Grid  Grid.Column="1"  HorizontalAlignment="Left">
                <Border Width="600" Height="350"  Background="White" CornerRadius="13" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Grid ShowGridLines="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- 用户名标签 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="用户名：" FontSize="25" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <!-- 用户名输入框 -->
                        <CustomControls:IconTextBox x:Name="UsernameTextBox" Grid.Row="0" Grid.Column="1" 
                                                    BorderThickness="0,0,0,1"
                                                    HorizontalAlignment="Left"
                                                    Watermark="请输入用户名"
                                                    FontSize="24"
                                                    Width="350" Height="50" 
                                                     IsPassword="False"
                                                    Icon="/Assets/username.png" />

                        <!-- 密码标签 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="密码：" HorizontalAlignment="Right" FontSize="25" VerticalAlignment="Center"/>
                        <CustomControls:IconTextBox x:Name="PasswordTextBox" Grid.Row="1" Grid.Column="1" 
                                                    HorizontalAlignment="Left"
                                                    BorderThickness="0,0,0,1" 
                                                    Watermark="请输入密码"
                                                    FontSize="24"
                                                    IsPassword="True"
                                                    Width="350"
                                                    Height="50"
                                                    Icon="/Assets/pwd.png" />

                        <!-- 记住密码复选框 -->
                        <CheckBox Name="RememberPasswordCheckBox"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              Grid.Row="2"
                              Grid.ColumnSpan="2"
                              Content="记住密码"
                              HorizontalAlignment="Left">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                        <!-- 登录按钮 -->
                        <CustomControls:RoundRectButton Grid.Row="3" Grid.ColumnSpan="2"
                                                        Width="250"
                                                        Height="50"
                                                        CornerRadius="25"
                                                        BorderWidth="0"
                                                        Background="Black"
                                                        Foreground="White"
                                                        IconSource="/Assets/loginbutton.png"
                                                        Click="LoginButton_Click"
                                                        Content="登录" />

                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="3" HorizontalAlignment="Center" >
            <StackPanel >
                <TextBlock FontSize="20" Text="㈜NEOX / 031-1234-5678"/>
                <TextBlock FontSize="20" Text="一行公司的宣传语" HorizontalAlignment="Center"/>
                <TextBlock  FontSize="20" Text="© 2021 统一媒体管理平台" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
