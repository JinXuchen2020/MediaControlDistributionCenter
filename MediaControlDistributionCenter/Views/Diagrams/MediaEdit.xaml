                                                        Padding="0"
                                                        materialDesign:ButtonAssist.CornerRadius="2"
                                                        Click="SelectRssColor_Click"
                                                        Background="#16171D"
                                                        BorderBrush="Gray">
                                                        <materialDesign:PackIcon Kind="FormatColorText" Foreground="#737B8A"  Width="22" Height="22"/>
                                                    </Button>
                                                </StackPanel>
