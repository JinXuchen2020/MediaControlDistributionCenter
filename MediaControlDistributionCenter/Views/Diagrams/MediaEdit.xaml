                                <materialDesign:Card Background="#16171D" Cursor="">
                                    <StackPanel>
                                        <Expander HorizontalAlignment="Stretch" Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_113}" Foreground="White" ExpandDirection="Down" IsExpanded="True" materialDesign:ExpanderAssist.ExpanderButtonPosition="Start"  Background="#16171D">
                                            <Border Margin="20,0" BorderThickness="0,1,0,0" BorderBrush="#404870">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,0" TextBlock.Foreground="White">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="X" Width="12" VerticalAlignment="Center"/>
                                                        <materialDesign:NumericUpDown Padding="5" BorderBrush="#404870" BorderThickness="1" Margin="10,0,0,0" ValueChanged="NumericUpDown_ValueChanged" Value="{Binding SelectedComponent.Left}" ValueStep="1" Minimum="0"/>
                                                        <TextBlock Text="Y" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                                        <materialDesign:NumericUpDown  Padding="5" BorderBrush="#404870" BorderThickness="1" Margin="10,0,0,0" ValueChanged="NumericUpDown_ValueChanged" Value="{Binding SelectedComponent.Top}" ValueStep="1" Minimum="0"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <TextBlock Text="W" Width="12" VerticalAlignment="Center"/>
                                                        <materialDesign:NumericUpDown Padding="5" BorderBrush="#404870" BorderThickness="1" Margin="10,0,0,0" Value="{Binding SelectedComponent.Width, UpdateSourceTrigger=PropertyChanged}" ValueStep="1" Minimum="0" Maximum="768" />
                                                        <TextBlock Text="H" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                                        <materialDesign:NumericUpDown Padding="5" BorderBrush="#404870" BorderThickness="1" Margin="8,0,0,0" Value="{Binding SelectedComponent.Height, UpdateSourceTrigger=PropertyChanged}" ValueStep="1" Minimum="0" Maximum="576"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Expander>
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedComponent}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedComponent.IsShowInfo}" Value="false">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Expander Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_114}" Foreground="White" ExpandDirection="Down" IsExpanded="True" materialDesign:ExpanderAssist.ExpanderButtonPosition="Start" Background="#16171D">
                                                <Border Margin="20,0" BorderThickness="0,1,0,0" BorderBrush="#404870">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left" TextBlock.Foreground="White">
                                                        <TabControl Width="auto" Height="auto" Cursor="Hand" materialDesign:ColorZoneAssist.Background="#16171D" materialDesign:ColorZoneAssist.Foreground="White">
                                                            <TabItem Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_115}">
                                                                <Border Width="250" Height="110" Margin="10,20,0,0" HorizontalAlignment="Left" Background="#2A3255" BorderBrush="#404870" BorderThickness="1" MouseDown="btnUpload_Click" materialDesign:ButtonAssist.CornerRadius="5">
                                                                    <materialDesign:PackIcon Kind="Upload" Foreground="White" Width="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </TabItem>
                                                            <TabItem Header="{DynamicResource LanguageKey_Code_MediaStore}" Cursor="">
                                                                <ScrollViewer VerticalScrollBarVisibility="Auto" Width="250" Margin="10,20,0,0">
                                                                    <materialDesign:Card Background="#16171D" Cursor="">
                                                                        <StackPanel>
                                                                            <StackPanel Orientation="Horizontal" Height="32" HorizontalAlignment="Left" Margin="0,0,0,10">
                                                                                <Border Background="{Binding SelectedType, Converter={StaticResource SelectedValueConverter}, ConverterParameter=All}" MouseDown="RefreshData_MouseDown" BorderBrush="#538AF0" BorderThickness="1" Cursor="Hand" CornerRadius="2" Margin="0,0,4,0" Width="80" Tag="All" >
                                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_All}" />
                                                                                    </StackPanel>
                                                                                </Border>
                                                                                <Border Background="{Binding SelectedType, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Video}" MouseDown="RefreshData_MouseDown" BorderBrush="#538AF0" BorderThickness="1" Cursor="Hand" CornerRadius="2" Margin="0,0,4,0" Width="80" Tag="Video">
                                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_103}" />
                                                                                    </StackPanel>
                                                                                </Border>

                                                                                <Border Background="{Binding SelectedType, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Image}" MouseDown="RefreshData_MouseDown" BorderBrush="#538AF0" BorderThickness="1" Cursor="Hand" CornerRadius="2" Margin="0,0,4,0" Width="80" Tag="Image">
                                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_104}" />
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </StackPanel>
                                                                            <StackPanel Orientation="Horizontal" Height="24" Margin="0,0,0,10" VerticalAlignment="Top" HorizontalAlignment="Left">
                                                                                <StackPanel Orientation="Horizontal" Background="#2A3255" Margin="0,0,0,0" >
                                                                                    <TextBox Height="24" Width="185" BorderBrush="#404870" BorderThickness="1" Text="{Binding SearchString}" FontSize="12" materialDesign:HintAssist.Hint="{DynamicResource LanguageKey_Code_Search_Hint}" Padding="5,0,0,0"  Foreground="White" />
                                                                                    <Button Background="#2A3255" Width="24" Height="24" Padding="0" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="MaterialDesignIconButton" Command="{Binding SearchCommand}">
                                                                                        <Image Width="24" Height="24" Source="/Assets/5.png" HorizontalAlignment="Left"/>
                                                                                    </Button>
                                                                                </StackPanel>
                                                                            </StackPanel>
                                                                            <ItemsControl ItemsSource="{Binding Medias}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <WrapPanel Orientation="Horizontal" ItemWidth="120" ItemHeight="110" />
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <StackPanel Orientation="Horizontal">
                                                                                            <!--<TextBlock Foreground="White" Text="{Binding Name}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14"/>-->
                                                                                            <Image Source="{Binding Thumbnail }" Stretch="Fill" MouseDown="CreateComponentFromStore_MouseDown" Width="110" Height="100" />
                                                                                        </StackPanel>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </materialDesign:Card>
                                                                </ScrollViewer>
                                                            </TabItem>
                                                        </TabControl>
                                                    </StackPanel>
                                                </Border>
                                            </Expander>
                                        </StackPanel>                                        
                                        <StackPanel>
                                            <ContentControl Content="{Binding SelectedComponent}" ContentTemplateSelector="{StaticResource ComponentDataTemplateSelector}" />                                            
                                        </StackPanel>
                                    </StackPanel>
                                </materialDesign:Card>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="{DynamicResource LanguageKey_Code_ProgramEdit_PageProperty}" Selector.IsSelected ="{Binding SelectedComponent, Converter={StaticResource NotEmptyConverter}, ConverterParameter=false}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <materialDesign:Card Background="#16171D">
                                    <StackPanel>
                                        <Expander HorizontalAlignment="Stretch" Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_116}" Foreground="White" ExpandDirection="Down" IsExpanded="True"  materialDesign:ExpanderAssist.ExpanderButtonPosition="Start" Background="#16171D">
                                            <Border Margin="20,0" BorderThickness="0,1,0,0" BorderBrush="#404870">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" TextBlock.Foreground="White">
                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Name}" Width="80" VerticalAlignment="Center"/>
                                                        <TextBox Text="{Binding SelectedPage.Name}" BorderBrush="#404870" BorderThickness="1" Width="150" Padding="5" Height="28" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_103}" Width="80"  Margin="0,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                            <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_Normal}" Tag="normal" Click="PageTypeChanged_Click" IsChecked="{Binding SelectedPage.Type, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=normal}" />
                                                            <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_AD}" Tag="ad" Margin="25,0,0,0" Click="PageTypeChanged_Click" IsChecked="{Binding SelectedPage.Type, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=ad}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Height="40">
                                                        <CheckBox IsChecked="{Binding SelectedPage.IsHasValidity}" VerticalAlignment="Center"/>
                                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_142}" Width="80" Padding="5" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Height="40" Visibility="{Binding SelectedPage.IsHasValidity, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}" >
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_143}" Width="80" VerticalAlignment="Center"/>
                                                        <DatePicker Width="150" Padding="5" VerticalAlignment="Center" BorderBrush="#404870" BorderThickness="1" SelectedDate="{Binding SelectedPage.ValidStartDate}" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Height="40" Visibility="{Binding SelectedPage.IsHasValidity, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_144}" Width="80" VerticalAlignment="Center"/>
                                                        <DatePicker Width="150" Padding="5" VerticalAlignment="Center" BorderBrush="#404870" BorderThickness="1" SelectedDate="{Binding SelectedPage.ValidEndDate}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Expander>
                                        <StackPanel Visibility="{Binding SelectedPage.Type, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=normal}">
                                            <Expander HorizontalAlignment="Stretch" Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_130}" Foreground="White" ExpandDirection="Down" IsExpanded="True" materialDesign:ExpanderAssist.ExpanderButtonPosition="Start" Background="#16171D">
                                                <Border Margin="20,0" BorderThickness="0,1,0,0" BorderBrush="#404870">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" TextBlock.Foreground="White">
                                                        <StackPanel Orientation="Horizontal" Height="40">
                                                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_131}" Width="80" VerticalAlignment="Center"/>
                                                            <materialDesign:NumericUpDown VerticalAlignment="Center" Value="{Binding SelectedPage.PlayCount, UpdateSourceTrigger=PropertyChanged}" Padding="5" Width="150" BorderBrush="#404870" BorderThickness="1" ValueStep="1" Minimum="0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Expander>
                                        </StackPanel>
                                        <StackPanel Visibility="{Binding SelectedPage.Type, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=ad}">
                                            <Expander HorizontalAlignment="Stretch" Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_198}" Foreground="White" ExpandDirection="Down" IsExpanded="True" materialDesign:ExpanderAssist.ExpanderButtonPosition="Start" Background="#16171D">
                                                <Border Margin="20,0" BorderThickness="0,1,0,0" BorderBrush="#404870">
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" TextBlock.Foreground="White">
                                                        <StackPanel Orientation="Horizontal" Height="40">
                                                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_131}" Width="80" VerticalAlignment="Center"/>
                                                            <materialDesign:NumericUpDown VerticalAlignment="Center" Value="{Binding SelectedPage.PlayCount, UpdateSourceTrigger=PropertyChanged}" Padding="5" Width="150" BorderBrush="#404870" BorderThickness="1" ValueStep="1" Minimum="0"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Height="40">
                                                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_200}" Width="80" VerticalAlignment="Center"/>
                                                            <materialDesign:NumericUpDown VerticalAlignment="Center" Value="{Binding SelectedPage.PlayGap, UpdateSourceTrigger=PropertyChanged}" Padding="5" Width="150" BorderBrush="#404870" BorderThickness="1" ValueStep="1" Minimum="0"/>
                                                        </StackPanel>
                                                        <WrapPanel Orientation="Vertical" VerticalAlignment="Center">
                                                            <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_201}" Tag="continuous" Click="AdPlayModeChanged_Click" IsChecked="{Binding SelectedPage.AdPlayMode, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=continuous}" />
                                                            <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_202}" Tag="gap" Margin="50,0,0,0" Click="AdPlayModeChanged_Click" IsChecked="{Binding SelectedPage.AdPlayMode, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=gap}" />
                                                            <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_203}" Tag="random" Click="AdPlayModeChanged_Click" IsChecked="{Binding SelectedPage.AdPlayMode, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=random}" />
                                                            <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_204}" Tag="perday" Margin="50,0,0,0" Click="AdPlayModeChanged_Click" IsChecked="{Binding SelectedPage.AdPlayMode, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=perday}" />
                                                            <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_205}" Tag="perhour" Margin="50,0,0,0" Click="AdPlayModeChanged_Click" IsChecked="{Binding SelectedPage.AdPlayMode, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=perhour}" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Expander>
                                        </StackPanel>
                                        <Expander HorizontalAlignment="Stretch" Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_145}" Foreground="White" ExpandDirection="Down" IsExpanded="True" materialDesign:ExpanderAssist.ExpanderButtonPosition="Start" Background="#16171D">
                                            <Border Margin="10,0" BorderThickness="0,1,0,0" BorderBrush="#404870">
                                                <ItemsControl ItemsSource="{Binding SelectedPage.Schedulers}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" TextBlock.Foreground="White">
                                                                <StackPanel Orientation="Horizontal" Height="40" HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding Id}" Width="13" VerticalAlignment="Center"/>
                                                                    <materialDesign:TimePicker SelectedTime="{Binding StartTime}" Width="80" Is24Hours="True" WithSeconds="True"  BorderBrush="#404870" Padding="5" VerticalAlignment="Center" BorderThickness="1"></materialDesign:TimePicker>
                                                                    <TextBlock Text="~" Margin="10,0,0,0" Width="20" VerticalAlignment="Center"/>
                                                                    <materialDesign:TimePicker SelectedTime="{Binding EndTime}" Width="80" Is24Hours="True" Padding="5" WithSeconds="True" VerticalAlignment="Center"  BorderBrush="#404870" BorderThickness="1"></materialDesign:TimePicker>
                                                                    <materialDesign:PackIcon Kind="AddCircle" MouseDown="AddScheduler_MouseDown" Margin="5,0,0,0" Foreground="LightGray" Cursor="Hand" VerticalAlignment="Center"  Width="22" Height="22"/>
                                                                    <materialDesign:PackIcon Kind="DeleteCircle" MouseDown="DeleteScheduler_MouseDown" Margin="2,0,0,0" Foreground="LightGray" Cursor="Hand" VerticalAlignment="Center"  Width="22" Height="22"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_146}" Margin="0,5"></TextBlock>
                                                                <StackPanel Orientation="Horizontal" Height="40">
                                                                    <ItemsControl ItemsSource="{Binding AllDays}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Button Width="28" Height="28" Padding="0" Margin="0,0,10,0" Click="SelectDay_Click" Content="{Binding DisplayName}" Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </Expander>
                                    </StackPanel>
                                </materialDesign:Card>

                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
