                                <TextBlock HorizontalAlignment="Left" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_191}" Width="80" VerticalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding Contents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,10,0,0">
                                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding FieldNameContent}" Tag="{Binding FieldName}" />
                                                <StackPanel Orientation="Horizontal" Margin="10">
                                                    <ComboBox Padding="5" Width="100" BorderBrush="#404870" BorderThickness="1" ItemsSource="{Binding Fonts}" SelectedValue="{Binding FontFamily}" />
                                                    <materialDesign:NumericUpDown Padding="5" Margin="10,0,0,0" Width="100" BorderBrush="#404870" BorderThickness="1" Value="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" ValueStep="1" Minimum="1"/>
                                                    <TextBlock Text="px" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Width="25" Height="25"
                                                        Margin="10,0,0,0"
                                                        Padding="0"
                                                        materialDesign:ButtonAssist.CornerRadius="2"
                                                        Click="SetRssFontStyle_Click"
                                                        Tag="Bold"
                                                        Background="{Binding IsBold, Converter={StaticResource SelectedValueConverter}}"
                                                        BorderBrush="Gray">
                                                        <materialDesign:PackIcon Kind="FormatBold" Foreground="#737B8A"  Width="22" Height="22"/>
                                                    </Button>
                                                    <Button Width="25" Height="25"
                                                        Margin="10,0,0,0"
                                                        Padding="0"
                                                        Click="SetRssFontStyle_Click"
                                                        Tag="Italic"
                                                        materialDesign:ButtonAssist.CornerRadius="2"
