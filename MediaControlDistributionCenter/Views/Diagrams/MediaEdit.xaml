                                                        <DatePicker Width="150" Padding="5" VerticalAlignment="Center" BorderBrush="#404870" BorderThickness="1" SelectedDate="{Binding SelectedPage.ValidStartDate}" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Height="40" Visibility="{Binding SelectedPage.IsHasValidity, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_144}" Width="80" VerticalAlignment="Center"/>
                                                        <DatePicker Width="150" Padding="5" VerticalAlignment="Center" BorderBrush="#404870" BorderThickness="1" SelectedDate="{Binding SelectedPage.ValidEndDate}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Expander>
                                        <Expander HorizontalAlignment="Stretch" Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_130}" Foreground="White" ExpandDirection="Down" IsExpanded="True" materialDesign:ExpanderAssist.ExpanderButtonPosition="Start" Background="#16171D">
                                            <Border Margin="20,0" BorderThickness="0,1,0,0" BorderBrush="#404870">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" TextBlock.Foreground="White">
                                                    <StackPanel Orientation="Horizontal" Height="40">
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_131}" Width="80" VerticalAlignment="Center"/>
                                                        <materialDesign:NumericUpDown VerticalAlignment="Center" Value="{Binding SelectedPage.PlayCount, UpdateSourceTrigger=PropertyChanged}" Padding="5" Width="150" BorderBrush="#404870" BorderThickness="1" ValueStep="1" Minimum="0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Expander>
                                        <Expander HorizontalAlignment="Stretch" Header="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_145}" Foreground="White" ExpandDirection="Down" IsExpanded="True" materialDesign:ExpanderAssist.ExpanderButtonPosition="Start" Background="#16171D">
                                            <Border Margin="10,0" BorderThickness="0,1,0,0" BorderBrush="#404870">
                                                <ItemsControl ItemsSource="{Binding SelectedPage.Schedulers}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" TextBlock.Foreground="White">
                                                                <StackPanel Orientation="Horizontal" Height="40" HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding Id}" Width="13" VerticalAlignment="Center"/>
                                                                    <materialDesign:TimePicker SelectedTime="{Binding StartTime}" Width="80" Is24Hours="True" WithSeconds="True"  BorderBrush="#404870" Padding="5" VerticalAlignment="Center" BorderThickness="1"></materialDesign:TimePicker>
                                                                    <TextBlock Text="~" Margin="10,0,0,0" Width="20" VerticalAlignment="Center"/>
                                                                    <materialDesign:TimePicker SelectedTime="{Binding EndTime}" Width="80" Is24Hours="True" Padding="5" WithSeconds="True" VerticalAlignment="Center"  BorderBrush="#404870" BorderThickness="1"></materialDesign:TimePicker>
                                                                    <materialDesign:PackIcon Kind="AddCircle" MouseDown="AddScheduler_MouseDown" Margin="5,0,0,0" Foreground="LightGray" Cursor="Hand" VerticalAlignment="Center"  Width="22" Height="22"/>
                                                                    <materialDesign:PackIcon Kind="DeleteCircle" MouseDown="DeleteScheduler_MouseDown" Margin="2,0,0,0" Foreground="LightGray" Cursor="Hand" VerticalAlignment="Center"  Width="22" Height="22"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_146}" Margin="0,5"></TextBlock>
                                                                <StackPanel Orientation="Horizontal" Height="40">
                                                                    <ItemsControl ItemsSource="{Binding AllDays}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Button Width="28" Height="28" Padding="0" Margin="0,0,10,0" Click="SelectDay_Click" Content="{Binding DisplayName}" Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </Expander>
                                    </StackPanel>
                                </materialDesign:Card>

                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
