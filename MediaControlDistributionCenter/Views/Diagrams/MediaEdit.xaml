<UserControl x:Class="MediaControlDistributionCenter.Views.MediaEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MediaControlDistributionCenter.Views"     
             xmlns:LocalCore="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"  
             xmlns:converters="clr-namespace:MediaControlDistributionCenter.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:MediaControlDistributionCenter.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:SelectedValueConverter x:Key="SelectedValueConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:IsEditingValueConverter x:Key="IsEditingValueConverter" />
        <converters:StringToTimeSpanConverter x:Key="StringToTimeSpanConverter" />
        <converters:NotEmptyConverter x:Key="NotEmptyConverter" />
        <Style x:Key="LeftAlignedCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LeftAlignedTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <materialDesign:DialogHost Identifier="RootDialogHostId">
        <materialDesign:DialogHost.DialogContentTemplate>
            <DataTemplate>
                <DataTemplate.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:MediaPageViewModel}">
                        <DockPanel LastChildFill="False" Background="#090A0E">
                            <Grid Width="500" Height="300" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Create}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Page}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Margin="10, 20, 10, 10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center">
                                        <TextBlock VerticalAlignment="Center" FontSize="16" Width="60" Text="{DynamicResource LanguageKey_Code_Name}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Height="32" Background="#2A3255" Padding="5" BorderBrush="#404870" BorderThickness="1" FontSize="16" Text="{Binding Name}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnPageSave_Click" />
                                    <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand }" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:MediaDevicesViewModel}">
                        <Border BorderThickness="1" Background="#090A0E">
                            <Grid Width="889" Height="600" Background="#090A0E" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Margin="20,12,0,12">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Media_SelectDeviceDialogTitle}" />
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0" HorizontalAlignment="Right">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=Close}" ToolTip="{DynamicResource LanguageKey_Code_SystemExitTip}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <Border Grid.Row="2" Margin="20,24,20,24" Height="400" BorderThickness="0,2,0,0" Background="#16171D">
                                    <Grid>
                                        <Border Background="#1A1E30" Height="40" VerticalAlignment="Top" />
                                        <DataGrid 
                                            AutoGenerateColumns="False" 
                                            CanUserAddRows="False"  
                                            FontSize="14" 
                                            IsReadOnly="True" 
                                            SelectionMode="Single"
                                            FrozenColumnCount="1" 
                                            Background="Transparent" 
                                            ItemsSource="{Binding Devices, UpdateSourceTrigger=PropertyChanged}"
                                        >
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Width="60"
                                                    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                    ElementStyle="{StaticResource LeftAlignedCheckBoxStyle}"
                                                    IsReadOnly="False"
                                                    CanUserSort="False">
                                                    <DataGridCheckBoxColumn.Header>
                                                        <CheckBox />
                                                    </DataGridCheckBoxColumn.Header>
                                                </DataGridCheckBoxColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Name}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_100}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding StatusText}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_101}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Resolution}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_102}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding MediaNames}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_103}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding SNumber}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_104}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Group}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_105}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="3" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>
                                <Grid Grid.Row="4">
                                    <StackPanel VerticalAlignment="Center" Margin="20,12,0,12" Orientation="Horizontal" HorizontalAlignment="Left">
                                        <TextBlock  FontSize="16" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_100}" />
                                        <TextBlock  FontSize="16" Margin="10,0,0,0" Text="{Binding CurrentMedia.Name}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="btnPublishSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Media_Send}" Click="btnPublishSave_Click" />
                                        <Button Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:TextComponentViewModel}">
                        <Border BorderThickness="1" Background="#090A0E">
                            <Grid Width="800" Height="600" Background="#090A0E" HorizontalAlignment="Center" Margin="10" >
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="280" />
                                    <RowDefinition Height="280" />
                                </Grid.RowDefinitions>
                                <StackPanel HorizontalAlignment="Right">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_100}" Width="80"/>
                                    <StackPanel Width="700">
                                        <materialDesign:ColorPicker x:Name="bgColorPicker" Color="{Binding Background}" Height="250" />
                                        <TextBlock Text="{Binding Background}" Width="700" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_100}" Width="80"/>
                                    <StackPanel Width="700">
                                        <materialDesign:ColorPicker x:Name="textColorPicker" Color="{Binding Foreground}" Height="250" />
                                        <TextBlock Text="{Binding Foreground}" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </DataTemplate.Resources>
                <ContentControl Content="{Binding}" />
            </DataTemplate>
        </materialDesign:DialogHost.DialogContentTemplate>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="2" />
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="308"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="308"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0" Grid.ColumnSpan="3">
                <Border Width="auto" Background="#16171D"/>
                <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeftThin" MouseDown="btnBack_MouseDown" Width="50" Cursor="Hand" Padding="0" Height="35" Foreground="White" />
                        <TextBlock Text="{Binding CurrentMedia.Name}" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </StackPanel.Resources>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Mixed" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-mixed.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_102}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Video" Cursor="Hand" MouseDown="CreateComponent_MouseDown" >
                            <Image Source="/Assets/svg-video.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_103}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Image" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-image.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_104}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Text" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-text.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_105}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Web" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-web.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_106}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Word" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-doc.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_107}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Rss" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-rss.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_108}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Stream" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-stream.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_109}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="ColorText" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-colortext.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_110}"/>
                        </StackPanel>
                    </Border>
                    <Border Width="60" Height="60" CornerRadius="5" Background="Transparent">
                        <StackPanel VerticalAlignment="Center" Tag="Hdmi" Cursor="Hand" MouseDown="CreateComponent_MouseDown">
                            <Image Source="/Assets/svg-hdmi.png" Width="30" Height="30"/>
                            <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_111}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                    <Button Background="#393C45" Margin="20,0,0,0"
                        BorderBrush="#393C45"
                        Width="35" Height="35"
                        Padding="0"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        ToolTip="MaterialDesignIconButton">
                        <materialDesign:PackIcon Kind="ChatQuestionOutline" Foreground="#8A94A5"  Width="30" Height="30"/>
                    </Button>
                    <Button Background="#393C45" Margin="20,0,0,0"
                        BorderBrush="#393C45"
                        Width="35" Height="35"
                        Padding="0"
                        Click="btnPreview_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        ToolTip="MaterialDesignIconButton">
                        <materialDesign:PackIcon Kind="PlayCircleOutline" Foreground="#8A94A5"  Width="30" Height="30"/>
                    </Button>
                    <Button Width="75" Height="35" Margin="20,0,0,0" Padding="0"
                        BorderBrush="LightGray"
                        Foreground="LightGray"
                        x:Name="btnSave"
                        Click="btnSave_Click"
                        IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center"  Foreground="White"/>
                                <TextBlock Margin="2" Text="{DynamicResource LanguageKey_Code_Save}" Foreground="White"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Width="85" Height="35" Margin="20,0,0,0" Padding="0"
                        BorderBrush="#30479C"
                        Background="#30479C"
                        Name="btnPublish"
                        Click="btnPublish_Click"
                        IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Send" VerticalAlignment="Center"  Foreground="White"/>
                                <TextBlock Margin="2" Text="{DynamicResource LanguageKey_Code_Media_Send}" Foreground="White"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
            <Border Grid.Row="1" Grid.ColumnSpan="3" Width="auto" Background="#40476F"/>

            <Border Grid.Row="2" Grid.Column="0" BorderThickness="0,0,2,0" BorderBrush="#40476F" Background="#16171D">
                <Grid>
                    <Border Width="auto" Background="#16171D"/>
                    <TabControl Width="auto" Height="auto" Cursor="Hand"
                        materialDesign:ColorZoneAssist.Background="#16171D"
                        materialDesign:ColorZoneAssist.Foreground="White"
                        SelectionChanged="LeftTab_SelectionChanged"
                        materialDesign:ColorZoneAssist.Mode="Custom">
                        <TabItem Header="{DynamicResource LanguageKey_Code_ProgramEdit_Media}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Top" HorizontalAlignment="Center">
                                        <!--<Button Width="22" Height="22" Padding="0" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="Add" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>-->
                                        <!--<Button Width="22" Height="22" Margin="15,0,0,0" Padding="0" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="ContentSave" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>-->
                                        <Button Width="22" Height="22" Margin="15,0,0,0" Padding="0" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="ArrowUp" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                        <Button Width="22" Height="22" Margin="15,0,0,0" Padding="0" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="ArrowDown" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                        <Button Width="22" Height="22" Margin="15,0,0,0" Padding="0" Click="btnComponentDelete_Click" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding SelectedPage.Components}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Expander Visibility="{Binding IsFile, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}" Margin="0,10" HorizontalAlignment="Stretch" Foreground="White" ExpandDirection="Down" IsExpanded="True" materialDesign:ExpanderAssist.HorizontalHeaderPadding="5" materialDesign:ExpanderAssist.HeaderBackground="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}" materialDesign:ExpanderAssist.ExpanderButtonPosition="Start" Background="#16171D" Cursor="">
                                                        <Expander.Header>
                                                            <DockPanel>
                                                                <LocalCore:CustomIcon Type="{Binding Type}" IsSelected="{Binding IsSelected}"  Width="30" Height="30"/>
                                                                <TextBlock Text="{Binding Name}" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="White" Cursor="Hand" />
                                                                <LocalCore:CustomIcon Type="Clean" MouseDown="ClearContent_MouseDown" Cursor="Hand" Width="22" Height="22" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,0,5,0" />
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <Border BorderThickness="0,0,0,0" BorderBrush="#404870">
                                                            <DockPanel Margin="10,10,0,0" Height="54" MouseDown="SelectComponent_MouseDown" Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}">
                                                                <LocalCore:CustomIcon Type="{Binding Type}" Margin="30,0,0,0" VerticalAlignment="Center" IsSelected="{Binding IsSelected}"  Width="30" Height="30" />
                                                                <TextBlock Margin="10,0,0,0" FontSize="14" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Text="{Binding FileName}"/>
                                                            </DockPanel>
                                                        </Border>
                                                    </Expander>
                                                    <DockPanel Visibility="{Binding IsFile, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=false}" Margin="0,10, 0, 0" Height="54" MouseDown="SelectComponent_MouseDown" Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}">
                                                        <LocalCore:CustomIcon Type="{Binding Type}" Margin="30,0,0,0" IsSelected="{Binding IsSelected}" Width="30" Height="30"/>
                                                        <TextBlock Margin="10,0,0,0" FontSize="14" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Text="{Binding Name}"/>
                                                        <LocalCore:CustomIcon Type="Clean" Cursor="Hand" MouseDown="ClearContent_MouseDown" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="LightGray"  Width="22" Height="22"/>
                                                    </DockPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="{DynamicResource LanguageKey_Code_ProgramEdit_Page}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Top" HorizontalAlignment="Center">
                                        <Button Width="22" Height="22" Padding="0" Click="btnPageAdd_Click" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="Add" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                        <Button Width="22" Height="22" Margin="15,0,0,0" Padding="0" Click="btnPageCapture_Click" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="ContentSave" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                        <Button Width="22" Height="22" Margin="15,0,0,0" Padding="0" Click="btnPageUpOrder_Click" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="ArrowUp" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                        <Button Width="22" Height="22" Margin="15,0,0,0" Padding="0" Click="btnPageDownOrder_Click" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="ArrowDown" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                        <Button Width="22" Height="22" Margin="15,0,0,0" Padding="0" Click="btnPageDelete_Click" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding MediaConfig.Pages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,10" Height="115" MouseDown="SelectPage_MouseDown"  Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}">
                                                    <TextBlock Margin="20,0,0,0" FontSize="14" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Text="{Binding Id}"/>
                                                    <Image Margin="10,0,0,0" Width="150" Height="100" Source="{Binding Thumbnail}"/>
                                                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                                        <TextBlock FontSize="14" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Text="{Binding Name}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                            <TextBlock FontSize="14" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Play}"/>
