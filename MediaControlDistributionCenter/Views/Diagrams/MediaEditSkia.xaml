<UserControl x:Class="MediaControlDistributionCenter.Views.Diagrams.MediaEditSkia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#16171D" BorderBrush="#404870" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="SkiaSharp Canvas Editor" 
                           Foreground="White" FontSize="16" 
                           VerticalAlignment="Center" Margin="10,0,0,0" />
                <Button x:Name="BtnBack" Content="← Back" 
                        HorizontalAlignment="Right" 
                        Background="#404870" Foreground="White"
                        BorderThickness="0" Padding="10,5"
                        Margin="0,0,10,0"
                        Click="BtnBack_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                          Background="#1D1E23" Width="280">
                <!-- Property panel content is bound via DataContext to MediaEditViewModel -->
                <StackPanel DataContext="{Binding SelectedComponent}" Margin="10">
                    <TextBlock Text="Component Properties" Foreground="White" FontSize="14" FontWeight="Bold" />
                    <Border Background="#16171D" BorderBrush="#404870" BorderThickness="1" Margin="0,10,0,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="{Binding Type}" Foreground="#888" FontSize="12" />
                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" Margin="0,5,0,0" />
                            <Separator Margin="0,5" />
                            <TextBlock Text="Position" Foreground="#888" FontSize="12" Margin="0,5,0,0" />
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="X" Foreground="#888" FontSize="10" />
                                    <TextBlock Text="{Binding Left, StringFormat=F0}" Foreground="White" FontSize="14" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Y" Foreground="#888" FontSize="10" />
                                    <TextBlock Text="{Binding Top, StringFormat=F0}" Foreground="White" FontSize="14" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Size" Foreground="#888" FontSize="12" Margin="0,10,0,0" />
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="W" Foreground="#888" FontSize="10" />
                                    <TextBlock Text="{Binding Width, StringFormat=F0}" Foreground="White" FontSize="14" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="H" Foreground="#888" FontSize="10" />
                                    <TextBlock Text="{Binding Height, StringFormat=F0}" Foreground="White" FontSize="14" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Z-Index" Foreground="#888" FontSize="12" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding ZIndex, StringFormat=F0}" Foreground="White" FontSize="14" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          Background="#1D1E23">
                <skia:SKElement
                    x:Name="SkCanvas"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="768" Height="576"
                    AllowDrop="True"
                    PaintSurface="SkCanvas_PaintSurface"
                    MouseDown="SkCanvas_MouseDown"
                    MouseMove="SkCanvas_MouseMove"
                    MouseUp="SkCanvas_MouseUp"
                    MouseWheel="SkCanvas_MouseWheel"
                    DragEnter="SkCanvas_DragEnter"
                    DragOver="SkCanvas_DragOver"
                    Drop="SkCanvas_Drop"
                />
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
