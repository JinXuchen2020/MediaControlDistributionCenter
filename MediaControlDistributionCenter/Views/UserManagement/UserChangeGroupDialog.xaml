<UserControl x:Class="MediaControlDistributionCenter.Views.UserManagement.UserChangeGroupDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:MediaControlDistributionCenter.Views.UserManagement"
             mc:Ignorable="d" 
             d:DesignHeight="493" d:DesignWidth="889">
    <DockPanel LastChildFill="False"  Background="#090A0E">
        <Grid Width="889" Height="493" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="10">
                <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Users_GroupDialogTitle}" />
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                <Button Width="60" Height="38" HorizontalAlignment="Right"
                    Background="#090A0E" Foreground="WhiteSmoke"
                    BorderThickness="0"
                    HorizontalContentAlignment="Center"
                    materialDesign:ColorZoneAssist.Mode="Custom"
                    materialDesign:ColorZoneAssist.Background="#090A0E"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" ToolTip="关闭"/>
            </StackPanel>

            <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

            <StackPanel Grid.Row="2" Margin="10">
                <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                    <TextBlock Width="40" VerticalAlignment="Center" Text="组：" />
                    <ComboBox x:Name="cbGroups" ItemsSource="{Binding Groups}" DisplayMemberPath="Name" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" />
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid DockPanel.Dock="Bottom">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                <Button x:Name="btnConfirm" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Users_Confirm}" Click="btnConfirm_Click" />
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
