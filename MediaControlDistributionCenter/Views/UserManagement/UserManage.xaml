<UserControl x:Class="MediaControlDistributionCenter.Views.UserManagement.UserManage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:CustomControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"             
             xmlns:viewmodels="clr-namespace:MediaControlDistributionCenter.ViewModels"
             xmlns:converters="clr-namespace:MediaControlDistributionCenter.Converters"
             xmlns:local="clr-namespace:MediaControlDistributionCenter.Views.UserManagement" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             Height="1024" Width="1440">
    <UserControl.Resources>
        <converters:IsEditingValueConverter x:Key="IsEditingValueConverter" />
        <converters:SelectedValueConverter x:Key="SelectedValueConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <materialDesign:DialogHost Identifier="RootDialogHostId" Background="#16171D" Margin="20,8,20,0" Placement="Center">
        <materialDesign:DialogHost.DialogContentTemplate>
            <DataTemplate>
                <DataTemplate.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:UserViewModel}">
                        <Grid Background="Transparent" IsHitTestVisible="True">
                            <i:Interaction.Behaviors>
                                <i:MouseDragElementBehavior ConstrainToParentBounds="False" />
                            </i:Interaction.Behaviors>
                            <DockPanel LastChildFill="False" Background="#090A0E">
                                <Grid Width="889" Height="600" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="2" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="10">
                                        <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Users_Register}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                        <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" ToolTip="{DynamicResource LanguageKey_Code_SystemExitTip}"/>
                                    </StackPanel>

                                    <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                    <StackPanel Grid.Row="2" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_100}" />
                                            <ComboBox ItemsSource="{Binding RoleList}" SelectedValue="{Binding Role}" SelectedValuePath="Role" DisplayMemberPath="RoleText" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_102}" />
                                            <TextBox Width="250"  IsEnabled="{Binding Id, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=0}" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Account}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10" >
                                            <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_101}" />
                                            <ComboBox IsEnabled="{Binding Role, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=user}" ItemsSource="{Binding Agents}" SelectedValue="{Binding AgentId}" SelectedValuePath="Account" DisplayMemberPath="Account" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10" >
                                            <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_103}" />
                                            <TextBox Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Name}" />
                                        </StackPanel>
                                        <StackPanel Margin="10"  Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock FontSize="16" Foreground="White" Width="80" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_111}" />
                                            <StackPanel>
                                                <Border Width="110" Height="110" HorizontalAlignment="Left" Background="#2A3255" BorderBrush="#404870" BorderThickness="1" MouseDown="btnUpload_MouseDown" materialDesign:ButtonAssist.CornerRadius="5"  Visibility="{Binding IsUpload, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=false}">
                                                    <materialDesign:PackIcon Kind="Upload" Foreground="White" Width="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Border Width="110" Height="110" Background="#0F0F10" BorderBrush="#404870" BorderThickness="1" HorizontalAlignment="Left" MouseDown="btnUpload_MouseDown" materialDesign:ButtonAssist.CornerRadius="5"  Visibility="{Binding IsUpload, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                                                    <Image Source="{Binding LogoThumbnail}" Width="110" Height="110" />
                                                </Border>
                                                <TextBlock FontSize="12" Foreground="White" Width="300" VerticalAlignment="Bottom" Margin="0,20,0,0" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_112}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_107}" />
                                            <ComboBox ItemsSource="{Binding Groups}" SelectedValue="{Binding SelectedGroupId}" SelectedValuePath="Id" DisplayMemberPath="Name" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_LoginPassword}" />
                                            <TextBox Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Password}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_109}" />
                                            <TextBox Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Region}" />
                                        </StackPanel>
                                        <StackPanel  Orientation="Horizontal" VerticalAlignment="Center" Margin="10">
                                            <TextBlock Foreground="White" VerticalAlignment="Center" Width="80" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_114}" />
                                            <ComboBox Height="32" Width="250" Background="#2A3255" Padding="5" ItemsSource="{Binding TimeZoneInfos}" SelectedValuePath="DisplayName" SelectedValue="{Binding TimeZone}"  BorderBrush="#404870" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_113}" />
                                            <TextBox AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Width="464" Height="64" Background="#2A3255" Padding="5" BorderBrush="#404870" BorderThickness="1" Foreground="White" Text="{Binding TagLine}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <Grid DockPanel.Dock="Bottom">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                        <Button x:Name="btnSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnSave_Click" />
                                        <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Grid>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:UserGroupViewModel}">
                        <DockPanel LastChildFill="False" Background="#090A0E">
                            <Grid Width="500" Height="300" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Create}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Users_GroupDialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" />
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Width="60" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Name}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Name}" />
                                    </StackPanel>

                                    <!--<StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Width="60" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Agent}" />
                                        <ComboBox x:Name="cbGroups" ItemsSource="{Binding Agents}" DisplayMemberPath="Name" SelectedValue="{Binding AgentId}" SelectedValuePath="Account" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" />
                                    </StackPanel>-->
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnGroupSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnGroupSave_Click" />
                                    <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                </DataTemplate.Resources>
                <ContentControl Content="{Binding}" />
            </DataTemplate>
        </materialDesign:DialogHost.DialogContentTemplate>
        <StackPanel>
            <!--界面导航-->
            <StackPanel Orientation="Horizontal" Margin="10,16,0,16">
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14" Text="{DynamicResource LanguageKey_Code_Management}" />
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14">/</TextBlock>
                <TextBlock Foreground="White" FontSize="13" Text="{DynamicResource LanguageKey_Code_Management_Users}" />
            </StackPanel>
            <!--<CustomControls:Breadcrumb BreadcrumbItems="{Binding BreadcrumbItems}" />-->
            <TextBlock VerticalAlignment="Center" FontSize="16" Margin="10,10" Foreground="White" Text="{DynamicResource LanguageKey_Code_Management_Users}" />

            <Grid Height="2">
                <Border Width="auto" Background="#40476F"/>
            </Grid>

            <Grid Background="#16171D" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="274" />
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Background="#1D1E23" Height="796">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="20,0,20,0">
                        <StackPanel DockPanel.Dock="Left"  Orientation="Horizontal">
                            <Image Width="24" Height="24"  Source="/Assets/assets-0009.png" HorizontalAlignment="Left" Margin="0,0,10,0"/>
                            <TextBlock FontSize="20" VerticalAlignment="Center" Height="24" Text="{DynamicResource LanguageKey_Code_Users_Tooltip_107}" Foreground="White"/>
                        </StackPanel>
                        <Button Visibility="{Binding ConnectionMode.Mode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Remote}" x:Name="btnGroupAdd" Width="20" Height="20" VerticalAlignment="Center" Click="btnGroupAdd_Click" DockPanel.Dock="Right" Background="#2A3255" Padding="0" BorderBrush="#404870">
                            <Image Width="20" Height="20"  Source="/Assets/7.png" HorizontalAlignment="Left"/>
                        </Button>
                    </DockPanel>
                    <StackPanel Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel MouseDown="StackPanel_MouseDown" Cursor="Hand" Orientation="Horizontal" Height="44" Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}">
                                        <CheckBox Width="24" IsChecked="{Binding IsSelected}" Style="{StaticResource MaterialDesignCheckBox}" Margin="20,0,10,0" />
                                        <TextBlock Foreground="White" VerticalAlignment="Center" Text="{Binding Name}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <Grid VerticalAlignment="Top" Margin="0,20,0,0" >
                        <StackPanel Orientation="Horizontal" Height="32" HorizontalAlignment="Left" Visibility="{Binding ConnectionMode.Mode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Remote}">
                            <Border Visibility="{Binding CurrentUser.Role, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=admin}" Background="#2A3255" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0" >
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnRegister" Cursor="Hand" VerticalAlignment="Center" Margin="15,4,15,4" MouseDown="btnRegister_MouseDown" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Users_Register}" />
                                </StackPanel>
                            </Border>
                            <Border Background="#2A3255" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnChangeGroup" VerticalAlignment="Center" Cursor="Hand" MouseDown="btnChangeGroup_MouseDown" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_ChangGroup}" />
                                </StackPanel>
                            </Border>

                            <Border Visibility="{Binding CurrentUser.Role, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=admin}" Background="#2A3255" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnDeleteAll" VerticalAlignment="Center" Cursor="Hand" MouseDown="btnDeleteAll_MouseDown" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Delete}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Height="32" Margin="0,0,20,0" VerticalAlignment="Top" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Background="#2A3255" Margin="16,0,0,0" >
                                <TextBox Height="32" Width="185" BorderBrush="#404870" BorderThickness="1" Text="{Binding SearchString}" FontSize="16" materialDesign:HintAssist.Hint="{DynamicResource LanguageKey_Code_Search_Hint}" Padding="12,0,0,0"  Foreground="White" />
                                <Button Background="#2A3255" Width="32" Height="32" Padding="0" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="MaterialDesignIconButton" Command="{Binding SearchCommand}">
                                    <Image Width="32" Height="32" Source="/Assets/5.png" HorizontalAlignment="Left"/>
                                </Button>
                            </StackPanel>
                            <!--<Button Margin="16,0,0,0" Background="#2A3255" Padding="0" BorderBrush="#404870">
                                <Image Width="14" Height="14" Source="/Assets/12.png" Margin="12,6" HorizontalAlignment="Left"/>
                            </Button>
                            <Button Margin="16,0,0,0" Background="#2A3255" Padding="0" BorderBrush="#404870">
                                <Image Width="14" Height="14" Source="/Assets/13.png" Margin="12,6" HorizontalAlignment="Left"/>
                            </Button>-->
                        </StackPanel>
                    </Grid>
                    
                    <Border Grid.Row="1" Height="670" Margin="0,10,10,0" BorderThickness="0,2,0,0" Background="#16171D">
                        <Grid>
                            <Border Background="#1A1E30" Height="40" VerticalAlignment="Top" />
                            <DataGrid 
                                Name="dgUsers"
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"  
                                FontSize="14" 
                                IsReadOnly="True" 
                                SelectionMode="Single"
                                FrozenColumnCount="1"
                                Background="Transparent" 
                                ItemsSource="{Binding Users}"
                            >
                                <DataGrid.Resources>
                                    <Style x:Key="LeftAlignedCheckBoxStyle" TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style x:Key="LeftAlignedTextBlockStyle" TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <CustomControls:BindingProxy x:Key="proxy" Data="{Binding ConnectionMode}" />
                                    <CustomControls:BindingProxy x:Key="user" Data="{Binding CurrentUser}" />
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Width="60"
                                        Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        ElementStyle="{StaticResource LeftAlignedCheckBoxStyle}"
                                        IsReadOnly="False"
                                        CanUserSort="False">
                                        <DataGridCheckBoxColumn.Header>
                                            <CheckBox Unchecked="SelectAll_Click" Checked="SelectAll_Click"/>
                                        </DataGridCheckBoxColumn.Header>
                                    </DataGridCheckBoxColumn>
                                    <DataGridTemplateColumn Width="160" >
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Function}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <Button 
                                                        Content="{DynamicResource LanguageKey_Code_Users_Control}" 
                                                        Name="btnControlUser" 
                                                        Margin="3" Height="28" Foreground="White"
                                                        Click="btnControlUser_Click"
                                                    />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Account}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Users_Tooltip_102}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Role}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Users_Tooltip_100}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Group}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Users_Tooltip_107}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding AgentId}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Users_Tooltip_101}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Name}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Users_Tooltip_103}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Region}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Users_Tooltip_109}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Visibility="{Binding Data.Mode, Source={StaticResource proxy}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Remote}" Width="180" >
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Operation}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <Button Content="{DynamicResource LanguageKey_Code_Edit}" Foreground="White" Name="btnEdit" Click="btnEdit_Click" Margin="3" Height="28" />
                                                    <Button Visibility="{Binding Data.Role, Source={StaticResource user}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=admin}" Content="{DynamicResource LanguageKey_Code_Delete}" Foreground="White" Name="btnDelete" Click="btnDelete_Click" Margin="3" Height="28" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </StackPanel>
    </materialDesign:DialogHost>
</UserControl>
