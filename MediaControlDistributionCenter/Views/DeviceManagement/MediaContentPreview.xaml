<Window x:Class="MediaControlDistributionCenter.Views.DeviceManagement.MediaContentPreview"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:MediaControlDistributionCenter.Views.DeviceManagement"
        mc:Ignorable="d"
        WindowStyle="None" Width="768" Height="676"
        WindowStartupLocation="Manual">
    <Grid>
        <Grid Background="#090A0E" MouseDown="DragMove_MouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="10">
                <TextBlock VerticalAlignment="Center" FontSize="20"  Height="38" Foreground="White" Text="{DynamicResource LanguageKey_Code_MediaStore_Preview_Title}" />
            </StackPanel>

            <Button Width="80" Height="60" HorizontalAlignment="Right"
                Background="#090A0E" Foreground="WhiteSmoke"
                BorderThickness="0"
                HorizontalContentAlignment="Center"
                materialDesign:ColorZoneAssist.Mode="Custom"
                materialDesign:ColorZoneAssist.Background="#090A0E"
                materialDesign:ButtonAssist.CornerRadius="5"
                Click="ExitButton_Click"
                Content="{materialDesign:PackIcon Size=35,Kind=Power}"/>

            <Border Grid.Row="1" Width="auto" Background="#40476F"/>
            <Canvas  
                Grid.Row="2"
                Name="MainCanvas"
                Background="Black"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                VerticalAlignment="Center"
                ClipToBounds="True"
                Width="768"
                Height="576"
            />
        </Grid>

        <!-- 加载页面 -->
        <Grid x:Name="LoadingOverlay" Visibility="Collapsed">
            <Border Background="Black" Opacity="0.5" />
            <TextBlock Text="{DynamicResource LanguageKey_Code_Loading}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="24"/>
        </Grid>

    </Grid>
</Window>
