                     />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>-->
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!--分页及统计说明-->
                        <Grid Grid.Row="2" Background="Transparent" HorizontalAlignment="Right" >
                            <WrapPanel  HorizontalAlignment="Right"
        Margin="6"
        DataContext="{Binding GridPagingService}">
                                <Button  Content="&lt;"  Background="Transparent" BorderBrush="Transparent"  Foreground="White"  Command="{Binding PrevPage}"  Margin="2"  >
                                </Button>


                                <ItemsControl  ItemsSource="{Binding PageNumberList}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Page}"    Background="Transparent" BorderBrush="Transparent"      Foreground="White"
                                        Command="{Binding GotoPage}"
                                        CommandParameter="{Binding Page}"
                                        Margin="2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content=">"    Background="Transparent" BorderBrush="Transparent"      Foreground="White"  Command="{Binding NextPage}" Margin="2" />
                            </WrapPanel>
                        </Grid>

                    </StackPanel>
