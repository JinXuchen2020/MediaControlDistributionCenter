<LocalCore:FrameControl x:Class="MediaControlDistributionCenter.Views.MediaContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:LocalCore="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
    xmlns:viewmodels="clr-namespace:MediaControlDistributionCenter.ViewModels"
    xmlns:converters="clr-namespace:MediaControlDistributionCenter.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
>
    <UserControl.Resources>
        <converters:IsEditingValueConverter x:Key="IsEditingValueConverter" />
        <converters:SelectedValueConverter x:Key="SelectedValueConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <materialDesign:DialogHost Identifier="RootDialogHostId" Background="#16171D" Margin="20,8,20,0" Placement="Center">
        <materialDesign:DialogHost.DialogContentTemplate>
            <DataTemplate>
                <DataTemplate.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:MediaViewModel}">
                        <Border BorderThickness="1" Background="#090A0E">
                            <DockPanel LastChildFill="False">
                                <Grid Width="800" Height="500" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="2" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="10">
                                        <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_MediaStore_MediaDialogTitle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                        <Button Width="60" Height="38" HorizontalAlignment="Right"
                                            Background="#090A0E" Foreground="WhiteSmoke"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Center"
                                            materialDesign:ColorZoneAssist.Mode="Custom"
                                            materialDesign:ColorZoneAssist.Background="#090A0E"
                                            materialDesign:ButtonAssist.CornerRadius="5"
                                            Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                            Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}"/>
                                    </StackPanel>

                                    <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_100}" />
                                            <TextBox Width="400"  Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Name}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_104}" />
                                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Width}" />
                                            <TextBox Width="230" Height="32" Margin="10,0,0,0"  Padding="5" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Width}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:TextFieldAssist.SuffixText="px"  />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Height}"/>
                                            <TextBox Width="250" Height="32" Margin="10,0,0,0" Padding="5" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Height}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:TextFieldAssist.SuffixText="px"  />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_101}" />
                                            <ComboBox materialDesign:HintAssist.Hint="{Binding Type}" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" SelectedValue="{Binding Type}" SelectedValuePath="Tag" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250">
                                                <ComboBoxItem Content="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_103}" Tag="Video"  />
                                                <ComboBoxItem Content="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_104}" Tag="Image"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Margin="10" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Width="80" Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_108}" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox IsEnabled="False" Width="250" Height="32" Margin="0,0,0,0" Padding="5" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Src}" />

                                                <Button Background="#2A3255" Margin="5,0,0,0"
                                                    BorderBrush="#404870"
                                                    Click="btnUpload_Click"
                                                    Content="{materialDesign:PackIcon Size=20,Kind=Upload}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="80" FontSize="16" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_102}" />
                                            <ComboBox materialDesign:HintAssist.Hint="{Binding GroupId}" ItemsSource="{Binding Groups}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding GroupId}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <Grid DockPanel.Dock="Bottom">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                        <Button DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnMediaSave_Click" />
                                        <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Click="btnMediaCancel_Click" />
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:MediaGroupViewModel}">
                        <DockPanel LastChildFill="False" Background="#090A0E">
                            <Grid Width="500" Height="300" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Create}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_MediaStore_GroupDialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" />
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Width="60" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Name}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Name}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnGroupSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnGroupSave_Click" />
                                    <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:MediaContentViewModel}">
                        <DockPanel LastChildFill="False"  Background="#090A0E">
                            <Grid Width="500" Height="300" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10">
                                    <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_MediaStore_GroupDialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" ToolTip="{DynamicResource LanguageKey_Code_SystemExitTip}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Width="40" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_102}" />
                                        <ComboBox ItemsSource="{Binding MediaGroups}" Margin="10,0,0,0" SelectedValue="{Binding SelectedGroupId}" DisplayMemberPath="Name" SelectedValuePath="Id" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnConfirm" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Confirm}" Click="btnConfirm_Click" />
                                    <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                </DataTemplate.Resources>
                <ContentControl Content="{Binding}" />
            </DataTemplate>
        </materialDesign:DialogHost.DialogContentTemplate>
        <StackPanel>
            <!--界面导航-->
            <StackPanel Orientation="Horizontal" Margin="10,16,0,16">
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14" Text="{DynamicResource LanguageKey_Code_MediaStore}" />
            </StackPanel>
            <!--<CustomControls:Breadcrumb BreadcrumbItems="{Binding BreadcrumbItems}" />-->
            <StackPanel Orientation="Horizontal" Height="32" HorizontalAlignment="Left" Margin="0,0,0,10">
                <Border Background="{Binding SelectedType, Converter={StaticResource SelectedValueConverter}, ConverterParameter=All}" MouseDown="RefreshData_MouseDown" BorderBrush="#538AF0" BorderThickness="1" Cursor="Hand" CornerRadius="2" Margin="0,0,4,0" Width="80" Tag="All" >
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_All}" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="(" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{Binding AllCount}" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text=")" />
                    </StackPanel>
                </Border>
                <Border Background="{Binding SelectedType, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Video}" MouseDown="RefreshData_MouseDown" BorderBrush="#538AF0" BorderThickness="1" Cursor="Hand" CornerRadius="2" Margin="0,0,4,0" Width="80" Tag="Video">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_103}" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="(" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{Binding VideoCount}" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text=")" />
                    </StackPanel>
                </Border>

                <Border Background="{Binding SelectedType, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Image}" MouseDown="RefreshData_MouseDown" BorderBrush="#538AF0" BorderThickness="1" Cursor="Hand" CornerRadius="2" Margin="0,0,4,0" Width="80" Tag="Image">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_104}" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="(" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{Binding ImageCount}" />
                        <TextBlock VerticalAlignment="Center" FontSize="16" Foreground="White" Text=")" />
                    </StackPanel>
                </Border>

            </StackPanel>

            <Grid Height="2">
                <Border Width="auto" Background="#40476F"/>
            </Grid>

            <Grid Background="#16171D" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="274" />
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Background="#1D1E23" Height="796">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="20,0,20,0">
                        <StackPanel DockPanel.Dock="Left"  Orientation="Horizontal">
                            <Image Width="24" Height="24"  Source="/Assets/assets-0009.png" HorizontalAlignment="Left" Margin="0,0,10,0"/>
                            <TextBlock FontSize="20" VerticalAlignment="Center" Height="24" Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_102}" Foreground="White"/>
                        </StackPanel>
                        <Button x:Name="btnGroupAdd" Width="20" Height="20" VerticalAlignment="Center" Click="btnGroupAdd_Click" DockPanel.Dock="Right" Background="#2A3255" Padding="0" BorderBrush="#404870">
                            <Image Width="20" Height="20"  Source="/Assets/7.png" HorizontalAlignment="Left"/>
                        </Button>
                    </DockPanel>
                    <StackPanel Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding MediaGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel MouseDown="StackPanel_MouseDown" Cursor="Hand" Height="44" Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}">
                                        <CheckBox Width="24" IsChecked="{Binding IsSelected}" Style="{StaticResource MaterialDesignCheckBox}" Margin="20,0,10,0" />
                                        <TextBlock Foreground="White" VerticalAlignment="Center" Text="{Binding Name}" />
                                        <Button Width="22" Height="22" DockPanel.Dock="Right" Click="btnGroupDelete_Click" Padding="0" Margin="0,0,10,0" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray" BorderThickness="0" HorizontalAlignment="Right">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <Grid VerticalAlignment="Top" Margin="0,20,0,0" >
                        <StackPanel Orientation="Horizontal" Height="32" HorizontalAlignment="Left">
                            <Border Background="#2A3255" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0" >
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Cursor="Hand" VerticalAlignment="Center" Margin="15,4,15,4" MouseDown="btnUploadStart_MouseDown" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Upload}" />
                                </StackPanel>
                            </Border>
                            <Border Background="#2A3255" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnChangeGroup" VerticalAlignment="Center" Cursor="Hand" MouseDown="btnChangeGroup_MouseDown" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_ChangGroup}" />
                                </StackPanel>
                            </Border>

                            <Border Background="#2A3255" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnDeleteAll" VerticalAlignment="Center" Cursor="Hand" MouseDown="btnDeleteAll_MouseDown" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Delete}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Height="32" Margin="0,0,20,0" VerticalAlignment="Top" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Background="#2A3255" Margin="16,0,0,0" >
                                <TextBox Height="32" Width="185" BorderBrush="#404870" BorderThickness="1" Text="{Binding SearchString}" FontSize="16" materialDesign:HintAssist.Hint="{DynamicResource LanguageKey_Code_Search_Hint}" Padding="12,0,0,0"  Foreground="White" />
                                <Button Background="#2A3255" Width="32" Height="32" Padding="0" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="MaterialDesignIconButton" Command="{Binding SearchCommand}">
                                    <Image Width="32" Height="32" Source="/Assets/5.png" HorizontalAlignment="Left"/>
                                </Button>
                            </StackPanel>
                            <!--<Button Margin="16,0,0,0" Background="#2A3255" Padding="0" BorderBrush="#404870">
                            <Image Width="14" Height="14" Source="/Assets/12.png" Margin="12,6" HorizontalAlignment="Left"/>
                        </Button>
                        <Button Margin="16,0,0,0" Background="#2A3255" Padding="0" BorderBrush="#404870">
                            <Image Width="14" Height="14" Source="/Assets/13.png" Margin="12,6" HorizontalAlignment="Left"/>
                        </Button>-->
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Height="670" Margin="0,10,10,0" BorderThickness="0,2,0,0" Background="#16171D">
                        <Grid>
                            <Border Background="#1A1E30" Height="40" VerticalAlignment="Top" />
                            <DataGrid 
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"  
                                FontSize="14" 
                                IsReadOnly="True" 
                                SelectionMode="Single"
                                FrozenColumnCount="1"
                                Background="Transparent" 
                                ItemsSource="{Binding Medias}"
                            >
                                <DataGrid.Resources>
                                    <Style x:Key="LeftAlignedCheckBoxStyle" TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style x:Key="LeftAlignedTextBlockStyle" TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Width="60"
                                        Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        ElementStyle="{StaticResource LeftAlignedCheckBoxStyle}"
                                        IsReadOnly="False"
                                        CanUserSort="False">
                                        <DataGridCheckBoxColumn.Header>
                                            <CheckBox Unchecked="SelectAll_Click" Checked="SelectAll_Click"/>
                                        </DataGridCheckBoxColumn.Header>
                                    </DataGridCheckBoxColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Name}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_100}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Type}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_101}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding MediaGroupName}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_102}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Size}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_103}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Resolution}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_MediaStore_Tooltip_104}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="230" >
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Operation}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <Button Content="{DynamicResource LanguageKey_Code_Edit}" Foreground="White" Name="btnEdit" Click="btnEdit_Click" Margin="3" Height="28" />
                                                    <Button Content="{DynamicResource LanguageKey_Code_Preview}" Foreground="White" Click="btnPreview_Click" Margin="3" Height="28" />
                                                    <Button Content="{DynamicResource LanguageKey_Code_Delete}" Foreground="White" Name="btnDelete" Click="btnDelete_Click" Margin="3" Height="28" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </StackPanel>
    </materialDesign:DialogHost>
</LocalCore:FrameControl>
