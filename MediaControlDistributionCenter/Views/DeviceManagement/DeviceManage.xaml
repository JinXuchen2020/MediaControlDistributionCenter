<UserControl x:Class="MediaControlDistributionCenter.Views.DeviceManagement.DeviceManage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MediaControlDistributionCenter.Views.DeviceManagement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:MediaControlDistributionCenter.Converters"
             xmlns:customControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls" xmlns:viewmodels="clr-namespace:MediaControlDistributionCenter.ViewModels"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:IsEditingValueConverter x:Key="IsEditingValueConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:SelectedValueConverter x:Key="SelectedValueConverter" />
    </UserControl.Resources>
    <materialDesign:DialogHost Identifier="RootDialogHostId" Margin="{Binding PageMargin}">
        <materialDesign:DialogHost.DialogContentTemplate>
            <DataTemplate>
                <DataTemplate.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:DeviceGroupViewModel}">
                        <DockPanel LastChildFill="False" Background="#090A0E" MouseDown="DragMove_MouseDown">
                            <Grid Width="500" Height="300" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Create}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Device_GroupDialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" ToolTip="{DynamicResource LanguageKey_Code_SystemExitTip}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Width="40" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Name}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" Text="{Binding Name}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnGroupSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnGroupSave_Click" />
                                    <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:DeviceViewModel}">
                        <DockPanel LastChildFill="False" Background="#090A0E">
                            <Grid Width="889" Height="500" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Create}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Device_DialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_106}" />
                                        <TextBlock VerticalAlignment="Center" FontSize="16" Margin="5,0" Text="{Binding OwnerName}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock VerticalAlignment="Center" Width="80" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_100}" />
                                        <TextBox  VerticalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" Text="{Binding Name}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock VerticalAlignment="Center" Width="80" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_104}" />
                                        <TextBox IsEnabled="{Binding Id, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=0}"  VerticalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" Text="{Binding SNumber}" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Row="4" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="10">
                                    <TextBlock VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_102}" />
                                </StackPanel>

                                <StackPanel Grid.Row="6" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Width}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" Text="{Binding Width}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:TextFieldAssist.SuffixText="px" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="6" Grid.Column="1" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Height}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" Text="{Binding Height}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:TextFieldAssist.SuffixText="px" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Margin="10">
                                    <TextBlock VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_107}" />
                                </StackPanel>

                                <StackPanel Grid.Row="8" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Start}" />
                                        <DatePicker Width="250" VerticalAlignment="Center" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" SelectedDate="{Binding StartDate}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="8" Grid.Column="1" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_End}" />
                                        <DatePicker Width="250" VerticalAlignment="Center" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" SelectedDate="{Binding EndDate}" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Row="9" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Margin="10">
                                    <TextBlock VerticalAlignment="Center"  FontSize="16" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_108}" />
                                </StackPanel>

                                <StackPanel Grid.Row="11" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_109}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" Text="{Binding ContactName}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="11" Grid.Column="1" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_110}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" Text="{Binding ContactNumber}" />
                                    </StackPanel>
                                </StackPanel>

                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnDeviceSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnDeviceSave_Click" />
                                    <Button x:Name="btnDeviceCancel" DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Click="btnDeviceCancel_Click" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:DeviceManageViewModel}">
                        <DockPanel LastChildFill="False"  Background="#090A0E">
                            <Grid Width="500" Height="300" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10">
                                    <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Device_GroupDialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Width="60" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_105}" />
                                        <ComboBox ItemsSource="{Binding DeviceGroups}" SelectedValue="{Binding SelectedGroupId}" DisplayMemberPath="Name" SelectedValuePath="Id" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnChangeGroupConfirm" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Confirm}" Click="btnChangeGroupConfirm_Click" />
                                    <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                </DataTemplate.Resources>
                <ContentControl Content="{Binding}" />
            </DataTemplate>
        </materialDesign:DialogHost.DialogContentTemplate>
        <StackPanel>
            <!--界面导航-->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,16" Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14" Text="{DynamicResource LanguageKey_Code_Management}" />
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14">/</TextBlock>
                <TextBlock Foreground="White" FontSize="13" Text="{DynamicResource LanguageKey_Code_Management_Device}" />
            </StackPanel>
            <!--<CustomControls:Breadcrumb BreadcrumbItems="{Binding BreadcrumbItems}" />-->
            <TextBlock VerticalAlignment="Center" FontSize="16" Margin="10,10" Foreground="White" Text="{DynamicResource LanguageKey_Code_Management_Device}"  Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}"/>

            <Grid Height="2"  Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                <Border Width="auto" Background="#40476F"/>
            </Grid>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="274" />
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Background="#1D1E23" Height="796">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="20,0,20,0">
                        <StackPanel DockPanel.Dock="Left"  Orientation="Horizontal">
                            <Image Width="24" Height="24"  Source="/Assets/assets-0009.png" HorizontalAlignment="Left" Margin="0,0,10,0"/>
                            <TextBlock FontSize="20" VerticalAlignment="Center" Height="24" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_105}" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ConnectionMode.Mode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Remote}">
                            <Button x:Name="btnGroupAdd" Visibility="{Binding LoginUser.Role, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=admin}" Width="20" Height="20" VerticalAlignment="Center" Click="btnGroupAdd_Click" DockPanel.Dock="Right" Background="#2A3255" Padding="0" BorderBrush="#404870">
                                <Image Width="20" Height="20"  Source="/Assets/7.png" HorizontalAlignment="Left"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                    <StackPanel Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding DeviceGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel MouseDown="StackPanel_MouseDown" Cursor="Hand"  Height="44" Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}">
                                        <CheckBox Width="24" IsChecked="{Binding IsSelected}" Style="{StaticResource MaterialDesignCheckBox}" Margin="20,0,10,0" />
                                        <TextBlock Foreground="White" VerticalAlignment="Center" Text="{Binding Name}" />
                                        <Button Width="22" Height="22" DockPanel.Dock="Right" Click="btnGroupDelete_Click" Padding="0" Margin="0,0,10,0" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray" BorderThickness="0" HorizontalAlignment="Right">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal" Height="32" HorizontalAlignment="Left" Visibility="{Binding ConnectionMode.Mode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Remote}">
                            <Border Background="#1D1E23" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0" Visibility="{Binding LoginUser.Role, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=admin}" >
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnCreate" VerticalAlignment="Center" Cursor="Hand" MouseDown="btnCreate_MouseDown" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Device_Create}" />
                                </StackPanel>
                            </Border>
                            <Border Background="#1D1E23" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnChangeGroup" MouseDown="btnChangeGroup_MouseDown" VerticalAlignment="Center" Cursor="Hand" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_ChangGroup}" />
                                </StackPanel>
                            </Border>
                            <Border Background="{Binding SelectDisabled, Converter={StaticResource SelectedValueConverter}, ConverterParameter=0, UpdateSourceTrigger=PropertyChanged}" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock MouseDown="ShowDisabledDevices_MouseDown"  VerticalAlignment="Center" Cursor="Hand" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_126}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Height="32" Margin="0,0,20,0" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Background="#2A3255" Margin="16,0,0,0" >
                                <TextBox Height="32" Width="200" BorderBrush="#404870" BorderThickness="1" Text="{Binding SearchString}" FontSize="16" materialDesign:HintAssist.Hint="{DynamicResource LanguageKey_Code_Monitor_Tooltip_111}" Padding="12,0,0,0"  Foreground="White"/>
                                <Button Background="#2A3255"                                
                                    Width="32" Height="32"
                                    Padding="0"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="MaterialDesignIconButton" Command="{Binding SearchCommand}">
                                    <Image Width="32" Height="32" Source="/Assets/5.png" HorizontalAlignment="Left"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!--结果表格-->
                    <Border  Grid.Row="1" Height="670" Margin="20,24,0,0" BorderThickness="0,2,0,0" Background="#16171D">
                        <Grid>
                            <Border Background="#1A1E30" Height="40" VerticalAlignment="Top" />

                            <DataGrid 
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"  
                                FontSize="14" 
                                IsReadOnly="True" 
                                SelectionMode="Single"
                                FrozenColumnCount="1" 
                                Background="Transparent" 
                                ItemsSource="{Binding Devices, UpdateSourceTrigger=PropertyChanged}"
                            >
                                <DataGrid.Resources>
                                    <Style x:Key="LeftAlignedCheckBoxStyle" TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style x:Key="LeftAlignedTextBlockStyle" TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <customControls:BindingProxy x:Key="proxy" Data="{Binding LoginUser}" />
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Width="60"
                                        Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        ElementStyle="{StaticResource LeftAlignedCheckBoxStyle}"
                                        IsReadOnly="False"
                                        CanUserSort="False">
                                        <DataGridCheckBoxColumn.Header>
                                            <CheckBox Unchecked="SelectAll_Click" Checked="SelectAll_Click"/>
                                        </DataGridCheckBoxColumn.Header>
                                    </DataGridCheckBoxColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Name}" >
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_100}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Group}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_105}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding StatusText}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_101}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="1*">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_103}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Text="{Binding MediaNames}" TextWrapping="Wrap"></TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Resolution}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_102}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="230" >
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Operation}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <Button Visibility="{Binding Data.Role, Source={StaticResource proxy}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=admin}" Content="{DynamicResource LanguageKey_Code_Upgrade}" Foreground="White" Name="btnEdit" Click="btnEdit_Click" Margin="3" Height="28" />
                                                    <Button Visibility="{Binding Data.Role, Source={StaticResource proxy}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=admin}" Content="{Binding EnableBtnContent}" Foreground="White" Name="btnDelete" Click="btnDelete_Click" Margin="3" Height="28" />
                                                    <Button Content="{DynamicResource LanguageKey_Code_Connect}" Foreground="White" Name="btnConnect" Click="btnConnect_Click" Margin="3" Height="28" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>
        </StackPanel>
        
    </materialDesign:DialogHost>
</UserControl>
