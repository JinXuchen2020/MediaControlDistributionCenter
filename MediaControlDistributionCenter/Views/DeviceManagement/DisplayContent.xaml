<LocalCore:FrameControl 
                      x:Class="MediaControlDistributionCenter.Views.DisplayContent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
     xmlns:LocalCore="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"  
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    
    >
    <Grid Background="#16171D"  Margin="20,8,20,0">
        <StackPanel   Margin="20,0,0,0">
            <!--界面导航-->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14">媒体管理</TextBlock>
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14">/</TextBlock>
                <TextBlock Foreground="White"   FontSize="14">控制</TextBlock>
            </StackPanel>
            <!--标题-->
            <TextBlock  VerticalAlignment="Center" FontSize="20" Margin="0,24" Foreground="White" >显示屏列表</TextBlock>
            <!--查询表单-->
            <Grid >
                <StackPanel Orientation="Horizontal" Height="32" HorizontalAlignment="Left">

                    <Border  Background="#30479C" CornerRadius="2" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Image  Width="18" Height="18" Margin="15,4,6,4" Source="/Assets/10.png" HorizontalAlignment="Left"/>
                            <TextBlock  VerticalAlignment="Center" Margin="0,4,15,4" FontSize="16" Foreground="White" >添加显示屏</TextBlock>
                        </StackPanel>
                    </Border>


                    <Border  Background="#2A3255" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Image  Width="18" Height="18" Margin="15,4,6,4" Source="/Assets/11.png" HorizontalAlignment="Left"/>
                            <TextBlock  VerticalAlignment="Center" Margin="0,4,15,4" FontSize="16" Foreground="White" >添加标签</TextBlock>
                        </StackPanel>
                    </Border>

                    <Border  Background="#2A3255" CornerRadius="2" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock  VerticalAlignment="Center" Margin="15,4,15,4" FontSize="16" Foreground="White" >变更工作组</TextBlock>
                        </StackPanel>
                    </Border>

                    <materialDesign:PopupBox   Opacity="0.7"   StaysOpen="False" HorizontalAlignment="Center"
PlacementMode="BottomAndAlignCentres"
PopupMode="Click">
                        <materialDesign:PopupBox.ToggleContent>
                            <Border  Background="#2A3255" CornerRadius="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock  VerticalAlignment="Center" Margin="15,6,8,6" FontSize="16" Foreground="White" >更多</TextBlock>
                                    <Image  Width="12" Height="12" Margin="0,4,15,4" Source="/Assets/14.png" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </materialDesign:PopupBox.ToggleContent>
                        <ListView Width="100">
                            <ListViewItem Width="90"  Cursor="Hand" Content="显示屏列表" Tag="显示屏列表"/>
                            <ListViewItem Width="90"  Cursor="Hand" Content="媒体文件" Tag="媒体文件"  />
                        </ListView>
                    </materialDesign:PopupBox>

                </StackPanel>

                <StackPanel Orientation="Horizontal" Height="32" Margin="0,0,20,0" HorizontalAlignment="Right">

                    <materialDesign:PopupBox    Opacity="0.7"  StaysOpen="False" HorizontalAlignment="Center"
PlacementMode="BottomAndAlignCentres"
PopupMode="Click">
                        <materialDesign:PopupBox.ToggleContent>
                            <Border  Background="#2A3255" CornerRadius="2">
                                <StackPanel Orientation="Horizontal"  Width="175" >
                                    <TextBlock  VerticalAlignment="Center" Margin="15,6,8,6" FontSize="16" Foreground="White" >请选择分辨率</TextBlock>
                                    <Image HorizontalAlignment="Right"  Width="12" Height="12" Margin="30,4,15,4" Source="/Assets/14.png" />
                                </StackPanel>
                            </Border>
                        </materialDesign:PopupBox.ToggleContent>
                        <ListView Width="175">
                            <ListViewItem Width="90"  Cursor="Hand" Content="分辨率1" Tag="分辨率1"/>
                            <ListViewItem Width="90"  Cursor="Hand" Content="分辨率2" Tag="分辨率2"  />
                        </ListView>
                    </materialDesign:PopupBox>
 
                    
                    <StackPanel Orientation="Horizontal"   Background="#2A3255" Margin="16,0,0,0" >
                        <TextBox Width="185" Height="32" BorderBrush="#404870" BorderThickness="1"   FontSize="16"   materialDesign:HintAssist.Hint="输入关键字搜索"        Padding="12,0,0,0"  Foreground="White"   ></TextBox>
                        <Image  Width="32" Height="32" Source="/Assets/5.png" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Button  Margin="16,0,0,0" Background="#2A3255" Padding="0" BorderBrush="#404870">
                        <Image  Width="14" Height="14" Source="/Assets/12.png" Margin="12,6" HorizontalAlignment="Left"/>
                    </Button>
                    <Button  Margin="16,0,0,0" Background="#2A3255" Padding="0" BorderBrush="#404870">
                        <Image  Width="14" Height="14" Source="/Assets/13.png" Margin="12,6" HorizontalAlignment="Left"/>
                    </Button>
                </StackPanel>
            </Grid>
            <!--结果表格-->
            <Border   Grid.Row="1" Height="670" Margin="0,24,0,0"    BorderThickness="0,2,0,0" Background="#16171D">
                <Grid>
                    <Border Background="#1A1E30" Height="40" VerticalAlignment="Top">

                    </Border>
                    <DataGrid AutoGenerateColumns="False" CanUserAddRows="False"  FontSize="14" IsReadOnly="True" SelectionMode="Single"
           DataContext="{Binding GridPagingService}" FrozenColumnCount="1" Background="Transparent"
           ItemsSource="{Binding Items}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Id}" Visibility="Collapsed" Header="id"  />
                            <DataGridTextColumn Width="1*" Binding="{Binding DeviceName}" Header="显示屏名称" />
                            <DataGridTextColumn Width="1*" Binding="{Binding State}" Header="状态"  />
                            <DataGridTextColumn Width="1*" Binding="{Binding Type}" Header="标签" />
                            <DataGridTextColumn Width="1*" Binding="{Binding Type}" Header="上次修改时间" />
                            <DataGridTextColumn Width="1*" Binding="{Binding Type}" Header="节目" />
                            <DataGridTextColumn Width="1*" Binding="{Binding Type}" Header="分辨率" />
                            <DataGridTemplateColumn Header="操作"  Width="160" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel   Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Button Content="截图"   Name="DataEdit"   Margin="3" Height="28"
                     Command="{Binding DataContext.DataEditCommand, RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=LocalCore:FrameControl}}"
                     CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}, Path=SelectedItem}"
                     />
                                            <Button Content="升级"   Name="DataFind"   Margin="3" Height="28"
Command="{Binding DataContext.DataFindCommand, RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=LocalCore:FrameControl}}"
CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}, Path=SelectedItem}"
/>
                                            <Button Content="发布" Name="DataDel"   Margin="3" Height="28"
                     Command="{Binding DataContext.DataDelCommand, RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=LocalCore:FrameControl}}"
                     CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}, Path=SelectedItem}"
                     />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!--分页及统计说明-->
            <Grid Grid.Row="2" Background="Transparent" HorizontalAlignment="Right" >
                <WrapPanel  HorizontalAlignment="Right"
        Margin="6"
        DataContext="{Binding GridPagingService}">
                    <Button  Content="&lt;"  Background="Transparent" BorderBrush="Transparent"  Foreground="White"  Command="{Binding PrevPage}"  Margin="2"  >
                    </Button>


                    <ItemsControl  ItemsSource="{Binding PageNumberList}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Page}"    Background="Transparent" BorderBrush="Transparent"      Foreground="White"
                                        Command="{Binding GotoPage}"
                                        CommandParameter="{Binding Page}"
                                        Margin="2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content=">"    Background="Transparent" BorderBrush="Transparent"      Foreground="White"  Command="{Binding NextPage}" Margin="2" />
                </WrapPanel>
            </Grid>

        </StackPanel>
    </Grid>
</LocalCore:FrameControl>
