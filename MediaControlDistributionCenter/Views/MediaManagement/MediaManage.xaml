<UserControl x:Class="MediaControlDistributionCenter.Views.MediaManagement.MediaManage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MediaControlDistributionCenter.Views.MediaManagement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:MediaControlDistributionCenter.Converters"
             xmlns:customControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls" xmlns:viewmodels="clr-namespace:MediaControlDistributionCenter.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MediaManageViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:SelectedValueConverter x:Key="SelectedValueConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:IsEditingValueConverter x:Key="IsEditingValueConverter" />
        <Style x:Key="LeftAlignedCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LeftAlignedTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <materialDesign:DialogHost Identifier="RootDialogHostId" Margin="{Binding PageMargin}">
        <materialDesign:DialogHost.DialogContentTemplate>
            <DataTemplate>
                <DataTemplate.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:ProgramGroupViewModel}">
                        <DockPanel LastChildFill="False" Background="#090A0E">
                            <Grid Width="500" Height="300" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Create}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Media_GroupDialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" ToolTip="{DynamicResource LanguageKey_Code_SystemExitTip}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Width="40" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Name}" />
                                        <TextBox VerticalAlignment="Center" Width="250" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Name}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnSave_Click" />
                                    <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:MediaManageViewModel}">
                        <DockPanel LastChildFill="False"  Background="#090A0E">
                            <Grid Width="500" Height="300" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10">
                                    <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Media_GroupDialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" ToolTip="关闭"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Margin="10">
                                        <TextBlock Width="80" VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_101}" />
                                        <ComboBox ItemsSource="{Binding MediaGroups}" Margin="10,0,0,0" SelectedValue="{Binding SelectedGroupId}" DisplayMemberPath="Name" SelectedValuePath="Id" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Height="32" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnConfirm" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Confirm}" Click="btnConfirm_Click" />
                                    <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                    <!--<DataTemplate DataType="{x:Type viewmodels:MediaDevicesViewModel}">
                        <Border BorderThickness="1" Background="#090A0E">
                            <Grid Width="889" Height="600" Background="#090A0E" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Margin="20,12,0,12">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Media_SelectDeviceDialogTitle}" />
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0" HorizontalAlignment="Right">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                    Background="#090A0E" Foreground="WhiteSmoke"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Center"
                                    materialDesign:ColorZoneAssist.Mode="Custom"
                                    materialDesign:ColorZoneAssist.Background="#090A0E"
                                    materialDesign:ButtonAssist.CornerRadius="5"
                                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                    Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}" ToolTip="{DynamicResource LanguageKey_Code_SystemExitTip}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <Border Grid.Row="2" Margin="20,24,20,24" Height="400" BorderThickness="0,2,0,0" Background="#16171D">
                                    <Grid>
                                        <Border Background="#1A1E30" Height="40" VerticalAlignment="Top" />
                                        <DataGrid 
                                            AutoGenerateColumns="False" 
                                            CanUserAddRows="False"  
                                            FontSize="14" 
                                            IsReadOnly="True" 
                                            SelectionMode="Single"
                                            FrozenColumnCount="1" 
                                            Background="Transparent" 
                                            ItemsSource="{Binding Devices, UpdateSourceTrigger=PropertyChanged}"
                                        >
                                            <DataGrid.Resources>
                                                <customControls:BindingProxy x:Key="proxy" Data="{Binding}" />
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Width="60"
                                                    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                    ElementStyle="{StaticResource LeftAlignedCheckBoxStyle}"
                                                    IsReadOnly="False"
                                                    CanUserSort="False">
                                                    <DataGridCheckBoxColumn.Header>
                                                        <CheckBox DataContext="{Binding Data, Source={StaticResource proxy}}" Unchecked="SelectDevicesAll_Click" Checked="SelectDevicesAll_Click" />
                                                    </DataGridCheckBoxColumn.Header>
                                                </DataGridCheckBoxColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Name}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_100}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding StatusText}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_101}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Resolution}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_102}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding MediaNames}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_103}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding SNumber}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_104}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Group}">
                                                    <DataGridTextColumn.Header>
                                                        <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_105}" />
                                                    </DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="3" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>
                                <Grid Grid.Row="4">
                                    <StackPanel VerticalAlignment="Center" Margin="20,12,0,12" Orientation="Horizontal" HorizontalAlignment="Left">
                                        <TextBlock FontSize="16" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_100}" />
                                        <TextBlock FontSize="16" Margin="10,0,0,0" Text="{Binding CurrentMedia.Name}" />
                                        --><!--<CheckBox Margin="30,0,0,0" FontSize="14" VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_Program_Tooltip_114}" IsChecked="{Binding IsCover, Converter={StaticResource IsEditingValueConverter}}" />--><!--
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="btnPublishSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Media_Send}" Click="btnPublishSave_Click" />
                                        <Button Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>-->
                    <DataTemplate DataType="{x:Type viewmodels:ProgramViewModel}">
                        <Border BorderThickness="1" Background="#090A0E">
                            <DockPanel LastChildFill="False">
                                <Grid Width="889" Height="500" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="2" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="10">
                                        <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Program_DialogTitle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                        <Button Width="60" Height="38" HorizontalAlignment="Right"
                                            Background="#090A0E" Foreground="WhiteSmoke"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Center"
                                            materialDesign:ColorZoneAssist.Mode="Custom"
                                            materialDesign:ColorZoneAssist.Background="#090A0E"
                                            materialDesign:ButtonAssist.CornerRadius="5"
                                            Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                            Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}"/>
                                    </StackPanel>

                                    <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="110" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_100}" />
                                            <TextBox Width="718"  Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Name}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="110" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_102}" />
                                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Width}" />
                                            <TextBox Width="230" Height="32" Margin="10,0,0,0"  Padding="5" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Width}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:TextFieldAssist.SuffixText="px"  />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_Height}"/>
                                            <TextBox Width="250" Height="32" Margin="10,0,0,0" Padding="5" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" Text="{Binding Height}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:TextFieldAssist.SuffixText="px"  />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Margin="10" Grid.ColumnSpan="2">
                                        <!--<StackPanel Orientation="Horizontal" Margin="10">
                                            <TextBlock Width="110" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_103}" />
                                            <ComboBox materialDesign:HintAssist.Hint="{Binding Type}" Padding="5" Height="32" BorderBrush="#404870" Background="#2A3255" BorderThickness="1" SelectedValue="{Binding Type}" SelectedValuePath="Tag" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250">
                                                <ComboBoxItem Content="{DynamicResource LanguageKey_Code_Program}" Tag="PROGRAM"  />
                                                <ComboBoxItem Content="{DynamicResource LanguageKey_Code_AD}" Tag="AD"/>
                                            </ComboBox>
                                        </StackPanel>-->
                                        <StackPanel Visibility="{Binding Type, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=AD}">
                                            <StackPanel Orientation="Horizontal" Margin="10">
                                                <TextBlock Width="130" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_112}" />
                                                <materialDesign:NumericUpDown VerticalAlignment="Center" Value="{Binding PlayCountPerHour, UpdateSourceTrigger=PropertyChanged}" Padding="5" Width="150" BorderBrush="#404870" BorderThickness="1" ValueStep="1" Minimum="0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="10">
                                                <TextBlock Width="110" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_142}" />
                                                <StackPanel Orientation="Horizontal" >
                                                    <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_Program_Tooltip_111}" Click="ValiditySelected_Click" Tag="false" IsChecked="{Binding IsHasValidity, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=false}" />
                                                    <RadioButton VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_142}" Margin="50,0,0,0" Click="ValiditySelected_Click" Tag="true" IsChecked="{Binding IsHasValidity, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=true}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="10" Visibility="{Binding IsHasValidity, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                                                <StackPanel Orientation="Horizontal" Height="40">
                                                    <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_143}" FontSize="16" Width="110" VerticalAlignment="Center"/>
                                                    <DatePicker Width="250" Height="32" SelectedDateFormat="Short" Padding="5" VerticalAlignment="Center" BorderBrush="#404870" BorderThickness="1" SelectedDate="{Binding ValidStartDate}" />
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Height="40" Margin="55,0,0,0">
                                                    <TextBlock Text="{DynamicResource LanguageKey_Code_ProgramEdit_Tooltip_144}" FontSize="16" Width="110" VerticalAlignment="Center"/>
                                                    <DatePicker Width="250" Height="32" Padding="5" SelectedDateFormat="Short" VerticalAlignment="Center" BorderBrush="#404870" BorderThickness="1" SelectedDate="{Binding ValidEndDate}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <Grid DockPanel.Dock="Bottom">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                        <Button DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnMediaSave_Click" />
                                        <Button DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Click="btnMediaCancel_Click" />
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </DataTemplate.Resources>
                <ContentControl Content="{Binding}" />
            </DataTemplate>
        </materialDesign:DialogHost.DialogContentTemplate>
        <StackPanel>
            <!--界面导航-->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,16" Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14" Text="{DynamicResource LanguageKey_Code_Management}" />
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14">/</TextBlock>
                <TextBlock Foreground="White" FontSize="13" Text="{DynamicResource LanguageKey_Code_Management_Media}" />
            </StackPanel>
            <!--<CustomControls:Breadcrumb BreadcrumbItems="{Binding BreadcrumbItems}" />-->
            <TextBlock VerticalAlignment="Center" FontSize="16" Margin="10,10" Foreground="White" Text="{DynamicResource LanguageKey_Code_Management_Media}"  Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}"/>

            <Grid Height="2"  Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                <Border Width="auto" Background="#40476F"/>
            </Grid>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="274" />
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Background="#1D1E23" Height="796">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="20,0,20,0">
                        <StackPanel DockPanel.Dock="Left"  Orientation="Horizontal">
                            <Image Width="24" Height="24"  Source="/Assets/assets-0009.png" HorizontalAlignment="Left" Margin="0,0,10,0"/>
                            <TextBlock FontSize="20" VerticalAlignment="Center" Height="24" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_101}" Foreground="White"/>
                        </StackPanel>
                        <Button x:Name="btnAdd" Width="20" Height="20" VerticalAlignment="Center" Click="btnAdd_Click" DockPanel.Dock="Right" Background="#2A3255" Padding="0" BorderBrush="#404870">
                            <Image Width="20" Height="20"  Source="/Assets/7.png" HorizontalAlignment="Left"/>
                        </Button>
                    </DockPanel>
                    <StackPanel Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding MediaGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel MouseDown="StackPanel_MouseDown" Cursor="Hand" Height="44" Background="{Binding IsSelected, Converter={StaticResource SelectedValueConverter}}">
                                        <CheckBox Width="24" IsChecked="{Binding IsSelected}" Style="{StaticResource MaterialDesignCheckBox}" Margin="20,0,10,0" />
                                        <TextBlock Foreground="White" VerticalAlignment="Center" Text="{Binding Name}" />
                                        <Button Width="22" Height="22" DockPanel.Dock="Right" Click="btnGroupDelete_Click" Padding="0" Margin="0,0,10,0" materialDesign:ButtonAssist.CornerRadius="2" Background="Transparent" BorderBrush="Gray" BorderThickness="0" HorizontalAlignment="Right">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Foreground="LightGray"  Width="22" Height="22"/>
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </Grid>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal" Height="32" HorizontalAlignment="Left">
                            <Border Background="#1D1E23" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnCreate" VerticalAlignment="Center" Cursor="Hand" MouseDown="btnCreate_MouseDown" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Media_Create}" />
                                </StackPanel>
                            </Border>
                            <Border Background="#1D1E23" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnPublish" Cursor="Hand" VerticalAlignment="Center" MouseDown="btnPublish_MouseDown" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Media_Send}" />
                                </StackPanel>
                            </Border>
                            <Border Background="#1D1E23" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnChangeGroup" MouseDown="btnChangeGroup_MouseDown" VerticalAlignment="Center" Cursor="Hand" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_ChangGroup}" />
                                </StackPanel>
                            </Border>
                            <Border Background="#1D1E23" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnCopy" MouseDown="btnCopy_MouseDown" VerticalAlignment="Center" Cursor="Hand" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Media_Copy}" />
                                </StackPanel>
                            </Border>

                            <Border Background="#1D1E23" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="btnDeleteAll" VerticalAlignment="Center" MouseDown="btnDeleteAll_MouseDown" Cursor="Hand" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Delete}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Height="32" Margin="0,0,20,0" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Background="#2A3255" Margin="16,0,0,0" >
                                <TextBox Height="32" Width="185" BorderBrush="#404870" BorderThickness="1" Text="{Binding SearchString}" FontSize="16" materialDesign:HintAssist.Hint="{DynamicResource LanguageKey_Code_Search_Hint}" Padding="12,0,0,0"  Foreground="White"></TextBox>
                                <Button Background="#2A3255" Width="32" Height="32" Padding="0" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="MaterialDesignIconButton" Command="{Binding SearchCommand}">
                                    <Image Width="32" Height="32" Source="/Assets/5.png" HorizontalAlignment="Left"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!--结果表格-->
                    <Border  Grid.Row="1" Height="670" Margin="20,24,0,0" BorderThickness="0,2,0,0" Background="#16171D">
                        <Grid>
                            <Border Background="#1A1E30" Height="40" VerticalAlignment="Top" />
                            <DataGrid 
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"  
                                FontSize="14" 
                                IsReadOnly="True" 
                                SelectionMode="Single"
                                FrozenColumnCount="1" 
                                Background="Transparent" 
                                ItemsSource="{Binding Medias}"
                            >
                                <DataGrid.Resources>
                                    <Style x:Key="LeftAlignedCheckBoxStyle" TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style x:Key="LeftAlignedTextBlockStyle" TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Width="50"
                                        Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        ElementStyle="{StaticResource LeftAlignedCheckBoxStyle}"
                                        IsReadOnly="False"
                                        CanUserSort="False">
                                        <DataGridCheckBoxColumn.Header>
                                            <CheckBox Unchecked="SelectAll_Click" Checked="SelectAll_Click" />
                                        </DataGridCheckBoxColumn.Header>
                                    </DataGridCheckBoxColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Name}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_100}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Type}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_103}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Group}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_101}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1.5*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding StatusText}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_101}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Resolution}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_102}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="1*" >
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_104}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" >
                                                    <TextBlock Text="{Binding Size}" />
                                                    <TextBlock Text="MB" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding ScreensCount}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_105}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding LastUpdatedTime}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_106}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding CreatedSource}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Program_Tooltip_107}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="240" >
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Operation}"/>
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <!--<Button Background="{Binding Status, Converter={StaticResource SelectedValueConverter}, ConverterParameter=2}" IsEnabled="{Binding Status, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=1;2}" Content="{Binding RackingBtnContent}" Foreground="White" Name="btnRacking" Click="btnRacking_Click" Margin="3" Height="28" />-->
                                                    <Button Content="{DynamicResource LanguageKey_Code_Edit}" Background="#30479C" Foreground="White" Name="btnEdit" Click="btnEdit_Click" Margin="3" Height="28" />
                                                    <Button Content="{DynamicResource LanguageKey_Code_Delete}" Background="#30479C" Foreground="White" Name="btnDelete" Click="btnDelete_Click" Margin="3" Height="28" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </StackPanel>
    </materialDesign:DialogHost>
</UserControl>
