<LocalCore:FrameControl x:Class="MediaControlDistributionCenter.Views.DeviceControlContent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"     
      xmlns:viewmodels="clr-namespace:MediaControlDistributionCenter.ViewModels"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:CustomControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
      xmlns:converters="clr-namespace:MediaControlDistributionCenter.Converters"
      xmlns:LocalCore="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"  
    >
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:IsEditingValueConverter x:Key="IsEditingValueConverter" />
        <converters:SplitStringConverter x:Key="SplitStringConverter" />
        <converters:SelectedValueConverter x:Key="SelectedValueConverter" />
        <converters:PercentageConverter x:Key="PercentageConverter" />
        <converters:MultiSelectedValueConverter x:Key="MultiSelectedValueConverter" />
    </UserControl.Resources>
    <materialDesign:DialogHost Identifier="RootDialogHostId" Margin="{Binding PageMargin}">
        <materialDesign:DialogHost.DialogContentTemplate>
            <DataTemplate>
                <DataTemplate.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:DeviceTimeControlViewModel}">
                        <DockPanel LastChildFill="False" Background="#090A0E">
                            <Grid Width="800" Height="400" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Create}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_DialogTitle}" />
                                </StackPanel>

                                <StackPanel HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                                    <StackPanel Margin="10" Orientation="Horizontal"  HorizontalAlignment="Left" Visibility="{Binding IsShow, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}" >
                                        <StackPanel>
                                            <TextBlock Visibility="{Binding Type, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Brightness}" VerticalAlignment="Center" FontSize="16" Width="100" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_119}" />
                                            <TextBlock Visibility="{Binding Type, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Volume}" VerticalAlignment="Center" FontSize="16" Width="100" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_120}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Slider VerticalAlignment="Center" Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="100" TickFrequency="10" Width="500" IsSnapToTickEnabled="True" TickPlacement="BottomRight" />
                                            <TextBox 
                                                Width="35" 
                                                Height="32" 
                                                Margin="5,0,0,0"
                                                Padding="5"
                                                BorderBrush="#404870"
                                                BorderThickness="1" 
                                                HorizontalAlignment="Right" 
                                                Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Background="#2A3255" Foreground="White" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Margin="10">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock VerticalAlignment="Center" FontSize="16" Width="100" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_114}" />
                                                <ComboBox materialDesign:HintAssist.Hint="{Binding RepeatMode}" SelectionChanged="RepeatMode_Changed" Padding="5" Foreground="White" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Width="500" Height="32" SelectedValue="{Binding RepeatMode}" SelectedValuePath="Tag" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <ComboBoxItem Content="{DynamicResource LanguageKey_Code_Everyday}" Tag="day" />
                                                    <ComboBoxItem Content="{DynamicResource LanguageKey_Code_Everyweek}" Tag="week" />
                                                    <ComboBoxItem Content="{DynamicResource LanguageKey_Code_Everymonth}" Tag="month" />
                                                    <ComboBoxItem Content="{DynamicResource LanguageKey_Code_Everyyear}" Tag="year" />
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Margin="100,10,0,0" Orientation="Horizontal"  Visibility="{Binding RepeatMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=week}">
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Sunday, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="30" Padding="0" Margin="0,0,10,0" Tag="Sunday" Click="SelectWeekDay_Click" Content="{DynamicResource LanguageKey_Code_Sunday}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Monday, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="30" Padding="0" Margin="0,0,10,0" Tag="Monday" Click="SelectWeekDay_Click" Content="{DynamicResource LanguageKey_Code_Monday}"  materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Tuesday, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="30" Padding="0" Margin="0,0,10,0" Tag="Tuesday" Click="SelectWeekDay_Click" Content="{DynamicResource LanguageKey_Code_Tuesday}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Wednesday, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="30" Padding="0" Margin="0,0,10,0" Tag="Wednesday" Click="SelectWeekDay_Click" Content="{DynamicResource LanguageKey_Code_Wednesday}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Thursday, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="30" Padding="0" Margin="0,0,10,0" Tag="Thursday" Click="SelectWeekDay_Click" Content="{DynamicResource LanguageKey_Code_Thursday}"  materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Friday, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="30" Padding="0" Margin="0,0,10,0" Tag="Friday" Click="SelectWeekDay_Click" Content="{DynamicResource LanguageKey_Code_Friday}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=Saturday, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="30" Padding="0" Margin="0,0,10,0" Tag="Saturday" Click="SelectWeekDay_Click" Content="{DynamicResource LanguageKey_Code_Saturday}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                            </StackPanel>
                                            <StackPanel Margin="100,10,0,0" Orientation="Horizontal" Visibility="{Binding RepeatMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=month}">
                                                <ItemsControl ItemsSource="{Binding MonthDays}">
                                                    <ItemsControl.Resources>
                                                        <CustomControls:BindingProxy x:Key="proxy" Data="{Binding RepeatString}" />
                                                    </ItemsControl.Resources>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"  Width="500"  />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Width="32" Height="32" Padding="0" Margin="0,10,10,0" Click="SelectMonthDay_Click" Content="{Binding}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" Tag="{Binding}" >
                                                                <Button.Background>
                                                                    <MultiBinding UpdateSourceTrigger="PropertyChanged" Converter="{StaticResource MultiSelectedValueConverter}">
                                                                        <Binding Path="Data" Source="{StaticResource proxy}"/>
                                                                        <Binding Path=""/>                                                                        
                                                                    </MultiBinding>
                                                                </Button.Background>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <WrapPanel Margin="80,10,0,0" Orientation="Horizontal" Width="500" Visibility="{Binding RepeatMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=year}">
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=January}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="January" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_January}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=February}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="February" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_February}"  materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=March}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="March" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_March}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=April}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="April" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_April}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=May}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="May" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_May}"  materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=June}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="June" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_June}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=July}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="July" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_July}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=August}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="August" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_August}"  materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=September}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="September" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_September}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=October}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="October" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_October}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=November}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="November" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_November}"  materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                                <Button Background="{Binding RepeatString, Converter={StaticResource SelectedValueConverter}, ConverterParameter=December}" Width="60" Height="30" Padding="0" Margin="0,10,10,0" Tag="December" Click="SelectYearMonth_Click" Content="{DynamicResource LanguageKey_Code_December}" materialDesign:ButtonAssist.CornerRadius="2" Foreground="White" BorderBrush="Gray" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Margin="10" Visibility="{Binding Type, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Brightness;Volume;TimeSync;Restart}">
                                        <StackPanel Orientation="Horizontal" >
                                            <TextBlock VerticalAlignment="Center" FontSize="16" Width="100" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_112}" />
                                            <!--<LocalCore:TimeTextBox Is24Hour="True"  Text="{Binding ExecuteTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="500" Height="32" />-->
                                            <materialDesign:TimePicker Width="500" Is24Hours="True" WithSeconds="True" VerticalAlignment="Center" Margin="0,0,0,0" Height="32" Foreground="White" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" SelectedTime="{Binding ExecuteTime}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Margin="10" Orientation="Horizontal" Visibility="{Binding Type, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Power}">
                                        <TextBlock VerticalAlignment="Center" FontSize="16" Width="100" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_112}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" FontSize="10" Width="45" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_130}" />
                                            <!--<LocalCore:TimeTextBox Is24Hour="True" Text="{Binding ExecuteTime, Converter={StaticResource SplitStringConverter}, ConverterParameter=0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="32" />-->
                                            <materialDesign:TimePicker Width="200" Is24Hours="True" WithSeconds="True" VerticalAlignment="Center" Margin="0,0,0,0" Height="32" Foreground="White" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" SelectedTime="{Binding ExecuteTime, Converter={StaticResource SplitStringConverter}, ConverterParameter=0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                            <TextBlock VerticalAlignment="Center" FontSize="10" Width="45" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_131}" />
                                            <!--<LocalCore:TimeTextBox Is24Hour="True" Text="{Binding ExecuteTime, Converter={StaticResource SplitStringConverter}, ConverterParameter=1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="32" />-->
                                            <materialDesign:TimePicker Width="200" Is24Hours="True" WithSeconds="True" VerticalAlignment="Center" Margin="0,0,0,0" Height="32" Foreground="White" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Padding="5" SelectedTime="{Binding ExecuteTime, Converter={StaticResource SplitStringConverter}, ConverterParameter=1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Row="5" Margin="10">
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                                <TextBlock Width="100" VerticalAlignment="Center" FontSize="16" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_115}" />
                                                <DatePicker Padding="5" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Width="240" Height="32" SelectedDate="{Binding StartDate}"></DatePicker>
                                            </StackPanel>
                                            <TextBlock Text="~" Margin="5,0" VerticalAlignment="Center" />
                                            <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                                <DatePicker Padding="5" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Width="240" Height="32" SelectedDate="{Binding EndDate}"></DatePicker>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button IsEnabled="{Binding IsSaving, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=false}" x:Name="btnTimeControlSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnTimeControlSave_Click" />
                                    <Button x:Name="btnTimeControlCancel" DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand }" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                </DataTemplate.Resources>
                <ContentControl Content="{Binding}" />
            </DataTemplate>
        </materialDesign:DialogHost.DialogContentTemplate>
        <StackPanel>
            <!--界面导航-->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,16" Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14" Text="{DynamicResource LanguageKey_Code_Management}" />
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14">/</TextBlock>
                <TextBlock Foreground="White" FontSize="13" Text="{DynamicResource LanguageKey_Code_Control_Device}" />
            </StackPanel>
            <!--<CustomControls:Breadcrumb BreadcrumbItems="{Binding BreadcrumbItems}" />-->
            <TextBlock VerticalAlignment="Center" FontSize="16" Margin="10,10" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_Device}"  Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}"/>

            <Grid Height="2"  Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                <Border Width="auto" Background="#40476F"/>
            </Grid>
            <Grid Background="#0F0F10" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="274"></ColumnDefinition>
                    <ColumnDefinition Width="415"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <StackPanel Background="#1D1E23">
                    <Border Cursor="Hand" Margin="0,40,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" Tag="Brightness" x:Name="Brightness" >
                        <StackPanel Margin="20,0,10,0" Height="44"  HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="31" Height="28"  Source="/Assets/1.png" Stretch="Uniform"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_100}" />
                        </StackPanel>
                    </Border>
                    <Border Cursor="Hand" Margin="0,20,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" x:Name="Volume" Tag="Volume"  >
                        <StackPanel  Margin="20,0,10,0" Height="44"  HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="31" Height="28"  Source="/Assets/2.png" Stretch="Uniform"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_101}" />
                        </StackPanel>
                    </Border>
                    <Border  Cursor="Hand" Margin="0,20,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" x:Name="TimeSync"  Tag="TimeSync" >
                        <StackPanel  Margin="20,0,10,0" Height="44" HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="31" Height="28"  Source="/Assets/3.png" Stretch="Uniform"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_102}" />
                        </StackPanel>
                    </Border>
                    <Border  Cursor="Hand" Margin="0,20,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" x:Name="Restart" Tag="Restart"  >
                        <StackPanel Margin="20,0,10,0" Height="44" HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="31" Height="28"  Source="/Assets/4.png" Stretch="Uniform"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_103}" />
                        </StackPanel>
                    </Border>
                    <Border  Cursor="Hand" Margin="0,20,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" x:Name="Power" Tag="Power"  >
                        <StackPanel Margin="20,0,10,0" Height="44" HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Power" VerticalAlignment="Center" Foreground="White"  Width="31" Height="28"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_Tooltip_129}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Background="#16171D">
                    <StackPanel  Orientation="Horizontal"  Margin="17,40,20,10" >
                        <StackPanel Orientation="Horizontal"   Background="#2A3255" Margin="0,0,20,0">
                            <TextBox Width="185" Height="32" BorderBrush="#404870" BorderThickness="1" materialDesign:HintAssist.Hint="{DynamicResource LanguageKey_Code_Search_Hint}" Padding="12,0,0,0" Text="{Binding SearchString}"  Foreground="White"></TextBox>
                            <Button Background="#2A3255"                                
                                Width="32" Height="32"
                                Padding="0"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                ToolTip="MaterialDesignIconButton" Click="btnSearch_Click" Command="{Binding SearchCommand}">
                                <Image Width="32" Height="32" Source="/Assets/5.png" HorizontalAlignment="Left"/>
                            </Button>
                        </StackPanel>
                        <!--<Border Background="#1D1E23" BorderBrush="#538AF0" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock MouseDown="btnDetectConnectedDevice" VerticalAlignment="Center" Cursor="Hand" Margin="15,4,15,4" FontSize="16" Foreground="White" Text="{DynamicResource LanguageKey_Code_Refresh}" />
                            </StackPanel>
                        </Border>-->
                        <!--<Button Background="Transparent" BorderBrush="#404870" Padding="0">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="12" Height="12" Margin="4,7" Source="/Assets/6.png" HorizontalAlignment="Left"/>
                                <TextBlock VerticalAlignment="Center" Margin="0,7,8,7" FontSize="16" Foreground="White" >分组筛选</TextBlock>
                            </StackPanel>
                        </Button>-->
                    </StackPanel>

                    <!--结果表格-->
                    <Border Grid.Row="1" Height="830" BorderThickness="0,2,0,0" Background="#16171D" Margin="17,0,17,0">
                        <Grid>
                            <Border Background="#1A1E30" Height="40" VerticalAlignment="Top"/>
                            <DataGrid 
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"  
                                FontSize="14" 
                                IsReadOnly="True" 
                                SelectionMode="Single" 
                                FrozenColumnCount="1"
                                Name="dgDevices"
                                SelectionChanged="DevicesDataGrid_SelectionChanged"
                                Background="Transparent"
                                ItemsSource="{Binding Devices}"
                            >
                                <DataGrid.Resources>
                                    <Style x:Key="LeftAlignedTextBlockStyle" TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Visibility ="Collapsed" Header="id"  />
                                    <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Name}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_100}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="1*">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_132}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Width="28" Height="28" VerticalAlignment="Center" Source="/Assets/assets-0016.png" Stretch="Uniform" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}"/>
                                                    <Image Width="28" Height="28" VerticalAlignment="Center" Source="/Assets/assets-0017.png" Stretch="Uniform" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter} , ConverterParameter=false}"/>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding ConnectedText}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!--分页及统计说明-->
                    <Grid Grid.Row="2" Background="Transparent" HorizontalAlignment="Center" >
                        <WrapPanel  HorizontalAlignment="Right" Margin="6" >
                            <Button  Content="&lt;"  Background="Transparent" BorderBrush="Transparent"  Foreground="White"  Command="{Binding PrevPage}"  Margin="2"  >
                            </Button>


                            <ItemsControl  ItemsSource="{Binding PageNumberList}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Page}"    Background="Transparent" BorderBrush="Transparent"      Foreground="White"
                                        Command="{Binding GotoPage}"
                                        CommandParameter="{Binding Page}"
                                        Margin="2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

