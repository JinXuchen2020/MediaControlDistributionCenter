<LocalCore:FrameControl x:Class="MediaControlDistributionCenter.Views.DeviceControlContent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"     
      xmlns:viewmodels="clr-namespace:MediaControlDistributionCenter.ViewModels"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
      xmlns:converters="clr-namespace:MediaControlDistributionCenter.Converters"
      xmlns:LocalCore="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"  
      Height="1024" Width="1440"
    >
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:IsEditingValueConverter x:Key="IsEditingValueConverter" />
    </UserControl.Resources>
    <materialDesign:DialogHost Identifier="RootDialogHostId" Margin="{Binding PageMargin}" Placement="RelativePoint">
        <materialDesign:DialogHost.DialogContentTemplate>
            <DataTemplate>
                <DataTemplate.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:DeviceTimeControlViewModel}">
                        <DockPanel LastChildFill="False" Background="#090A0E">
                            <Grid Width="889" Height="400" HorizontalAlignment="Center" Margin="10" DockPanel.Dock="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Create}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_DialogTitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="10">
                                    <Button Width="60" Height="38" HorizontalAlignment="Right"
                                        Background="#090A0E" Foreground="WhiteSmoke"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Center"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Background="#090A0E"
                                        materialDesign:ButtonAssist.CornerRadius="5"
                                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                        Content="{materialDesign:PackIcon Size=20,Kind=CloseCircleOutline}"/>
                                </StackPanel>

                                <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="10, 20, 10, 10" Visibility="{Binding IsShow, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}" >
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock VerticalAlignment="Center" FontSize="16" Width="100" Text="{Binding CommandTypeColumnName}" />
                                        <StackPanel Orientation="Horizontal">
                                            <Slider VerticalAlignment="Center" Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="100" TickFrequency="10" Width="400" IsSnapToTickEnabled="True" TickPlacement="BottomRight" />
                                            <TextBox 
                                                Width="35" 
                                                Height="32" 
                                                Margin="10,0,0,0"
                                                Padding="5"
                                                BorderBrush="#404870"
                                                BorderThickness="1" 
                                                HorizontalAlignment="Right" 
                                                Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Background="#2A3255" Foreground="White" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" FontSize="16" Width="100" Text="执行时间：" />
                                        <materialDesign:TimePicker Padding="5" BorderBrush="#404870" BorderThickness="1" Is24Hours="True" WithSeconds="True" Background="#2A3255" Width="250" Height="32" Text="{Binding ExecuteTime}"></materialDesign:TimePicker>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Margin="10">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <TextBlock VerticalAlignment="Center" FontSize="16" Width="100" Text="执行方式：" />
                                        <ComboBox materialDesign:HintAssist.Hint="{Binding RepeatMode}" Padding="5" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Width="250" Height="32" SelectedValue="{Binding RepeatMode}" SelectedValuePath="Content" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <ComboBoxItem Content="每天一次"/>
                                            <ComboBoxItem Content="每周一次"/>
                                            <ComboBoxItem Content="每月一次"/>
                                            <ComboBoxItem Content="每季一次"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock Width="100" FontSize="16" VerticalAlignment="Center" Text="有效期开始：" />
                                        <DatePicker Padding="5" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Width="250" Height="32" SelectedDate="{Binding StartDate}"></DatePicker>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Grid.Column="1" Margin="10">
                                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                                        <TextBlock Width="100" FontSize="16" VerticalAlignment="Center" Text="有效期结束：" />
                                        <DatePicker Padding="5" BorderBrush="#404870" BorderThickness="1" Background="#2A3255" Width="250" Height="32" SelectedDate="{Binding EndDate}"></DatePicker>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Grid DockPanel.Dock="Bottom">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,25" Width="209">
                                    <Button x:Name="btnTimeControlSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Save}" Click="btnTimeControlSave_Click" />
                                    <Button x:Name="btnTimeControlCancel" DockPanel.Dock="Right" Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand }" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </DataTemplate>
                </DataTemplate.Resources>
                <ContentControl Content="{Binding}" />
            </DataTemplate>
        </materialDesign:DialogHost.DialogContentTemplate>
        <StackPanel>
            <!--界面导航-->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,16" Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14" Text="{DynamicResource LanguageKey_Code_Management}" />
                <TextBlock Foreground="White" Opacity="0.7" FontSize="14">/</TextBlock>
                <TextBlock Foreground="White" FontSize="13" Text="{DynamicResource LanguageKey_Code_Control_Device}" />
            </StackPanel>
            <!--<CustomControls:Breadcrumb BreadcrumbItems="{Binding BreadcrumbItems}" />-->
            <TextBlock VerticalAlignment="Center" FontSize="16" Margin="10,10" Foreground="White" Text="{DynamicResource LanguageKey_Code_Control_Device}"  Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}"/>

            <Grid Height="2"  Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
                <Border Width="auto" Background="#40476F"/>
            </Grid>
            <Grid Background="#0F0F10" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="274"></ColumnDefinition>
                    <ColumnDefinition Width="396"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <StackPanel Background="#1D1E23">
                    <Border Cursor="Hand" Margin="0,40,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" Tag="Brightness" x:Name="Brightness" >
                        <StackPanel Margin="20,0,10,0" Height="44"  HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="31" Height="28"  Source="/Assets/1.png" Stretch="Uniform"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" >亮度调节</TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Cursor="Hand" Margin="0,20,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" x:Name="Volume" Tag="Volume"  >
                        <StackPanel  Margin="20,0,10,0" Height="44"  HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="31" Height="28"  Source="/Assets/2.png" Stretch="Uniform"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" >音量调节</TextBlock>
                        </StackPanel>
                    </Border>
                    <Border  Cursor="Hand" Margin="0,20,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" x:Name="TimeSync"  Tag="TimeSync" >
                        <StackPanel  Margin="20,0,10,0" Height="44" HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="31" Height="28"  Source="/Assets/3.png" Stretch="Uniform"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" >对时配置</TextBlock>
                        </StackPanel>
                    </Border>
                    <Border  Cursor="Hand" Margin="0,20,0,0" MouseLeftButtonDown="Menu_MouseLeftButtonDown" x:Name="Restart" Tag="Restart"  >
                        <StackPanel Margin="20,0,10,0" Height="44" HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="31" Height="28"  Source="/Assets/4.png" Stretch="Uniform"/>
                            <TextBlock  VerticalAlignment="Center" Margin="13,0,0,0" FontSize="16" Foreground="White" >重启</TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Background="#16171D">
                    <StackPanel  Orientation="Horizontal"  Margin="17,40,20,10" >
                        <StackPanel Orientation="Horizontal"   Background="#2A3255" Margin="0,0,20,0">
                            <TextBox Width="185" Height="32" BorderBrush="#404870" BorderThickness="1" materialDesign:HintAssist.Hint="输入关键字搜索" Padding="12,0,0,0"  Foreground="White"></TextBox>
                            <Image  Width="32" Height="32" Source="/Assets/5.png" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <Button Background="Transparent" BorderBrush="#404870" Padding="0">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="12" Height="12" Margin="4,7" Source="/Assets/6.png" HorizontalAlignment="Left"/>
                                <TextBlock VerticalAlignment="Center" Margin="0,7,8,7" FontSize="16" Foreground="White" >分组筛选</TextBlock>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!--结果表格-->
                    <Border Grid.Row="1" Height="830" BorderThickness="0,2,0,0" Background="#16171D" Margin="17,0,35,0">
                        <Grid>
                            <Border Background="#1A1E30" Height="40" VerticalAlignment="Top"/>
                            <DataGrid 
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"  
                                FontSize="14" 
                                IsReadOnly="True" 
                                SelectionMode="Single" 
                                FrozenColumnCount="1"
                                Name="dgDevices"
                                Background="Transparent" 
                                SelectionChanged="DataGrid_SelectionChanged"
                                ItemsSource="{Binding Devices}"
                            >
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Id}" Visibility ="Collapsed" Header="id"  />
                                    <DataGridTextColumn Width="1*" Binding="{Binding Name}" Header="显示屏名称" />
                                    <DataGridTextColumn Width="1*" Binding="{Binding StatusText}" Header="状态"  />
                                    <!--<DataGridTextColumn Width="1*" Binding="{Binding Type}" Header="类型" />-->
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!--分页及统计说明-->
                    <Grid Grid.Row="2" Background="Transparent" HorizontalAlignment="Center" >
                        <WrapPanel  HorizontalAlignment="Right" Margin="6"  DataContext="{Binding GridPagingService}">
                            <Button  Content="&lt;"  Background="Transparent" BorderBrush="Transparent"  Foreground="White"  Command="{Binding PrevPage}"  Margin="2"  >
                            </Button>


                            <ItemsControl  ItemsSource="{Binding PageNumberList}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Page}"    Background="Transparent" BorderBrush="Transparent"      Foreground="White"
                                        Command="{Binding GotoPage}"
                                        CommandParameter="{Binding Page}"
                                        Margin="2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content=">"    Background="Transparent" BorderBrush="Transparent"      Foreground="White"  Command="{Binding NextPage}" Margin="2" />
                        </WrapPanel>
                    </Grid>
                </StackPanel>

                <Grid x:Name="BrightnessPara" Grid.Column="2" Margin="0,0,10,0" Background="#16171D">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="81"></RowDefinition>
                        <RowDefinition ></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.RowSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="81"></RowDefinition>
                            <RowDefinition ></RowDefinition>
                        </Grid.RowDefinitions>
                        <Border Grid.RowSpan="2" Margin="0,5,0,0" HorizontalAlignment="Left" BorderThickness="0.5" BorderBrush="#404870"></Border>
                        <Border Margin="0,0,5,0" VerticalAlignment="Bottom" BorderThickness="0.5" BorderBrush="#404870"></Border>
                    </Grid>
                    <StackPanel Margin="19,7,8,7" Orientation="Horizontal" >
                        <TextBlock  VerticalAlignment="Center" FontSize="16" Foreground="White" Text="显示屏："/>
                        <TextBlock  VerticalAlignment="Center" FontSize="16" Foreground="White" Text="{Binding CurrentDevice.Name}" />
                    </StackPanel>

                    <Grid Grid.Row="1" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="320"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <StackPanel>
                                <TextBlock Margin="19,32"  VerticalAlignment="Center" FontSize="20" Foreground="White" Text="实时控制" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="38,5,48,0" HorizontalAlignment="Left"  VerticalAlignment="Top" FontSize="16" Foreground="White" Text="{Binding CommandTypeName}" />
                                    <StackPanel Visibility="{Binding CommandType, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Brightness;Volume}">
                                        <StackPanel Orientation="Horizontal">
                                            <Slider VerticalAlignment="Center" Value="{Binding CommandRTValue, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="100" TickFrequency="10" Width="400" IsSnapToTickEnabled="True" TickPlacement="BottomRight" />
                                            <TextBox 
                                                Width="35" 
                                                Height="32" 
                                                Margin="10,0,0,0"
                                                Padding="5"
                                                BorderBrush="#404870"
                                                BorderThickness="1" 
                                                HorizontalAlignment="Right" 
                                                Text="{Binding CommandRTValue, UpdateSourceTrigger=PropertyChanged}" Background="#2A3255" Foreground="White" />
                                        </StackPanel>
                                        <TextBlock Margin="38,32,48,0" HorizontalAlignment="Left"  VerticalAlignment="Top" FontSize="16" Foreground="White"
                                           Width="378" TextWrapping="Wrap" Opacity="0.6" Text="{Binding CommandTypeDesciption}" />
                                        <Button Content="应用" Background="#30479C" Foreground="White" BorderThickness="0" Width="60" Height="30" FontSize="14" Margin="0,32,0,0" Click="Brightness_Click" />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding CommandType, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Restart}">
                                        <TextBlock Margin="0,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="14" Foreground="White" Text="{Binding CommandTypeHint}" Width="550" TextWrapping="Wrap" />
                                        <TextBlock Margin="10,32,10,10" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="14" Foreground="White" Text="{Binding CommandTypeDesciption}" Width="500" TextWrapping="Wrap" Opacity="0.6" />
                                        <Button Content="立即重启" Background="#30479C" Foreground="White" BorderThickness="0" Width="120" Height="30" FontSize="14" Margin="0,32,0,0" Click="Restart_Click" />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding CommandType, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=TimeSync}">
                                        <ComboBox materialDesign:HintAssist.Hint="{Binding CommandTypeHint}" Padding="12,0,0,0" Height="32" Width="464" Background="#2A3255"  ItemsSource="{Binding TimeZoneInfos}" SelectedValuePath="Id" SelectedValue="{Binding CommandRTValue}"  BorderBrush="#404870" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" />
                                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                            <TextBlock Grid.Row="2" Margin="0,0,19,0" FontSize="16" Foreground="White" VerticalAlignment="Center" >对时模式</TextBlock>
                                            <StackPanel Height="32"  VerticalAlignment="Center" Orientation="Horizontal">
                                                <CheckBox Click="ChangeTimeSyncMode_Click" IsChecked="{Binding CommandTypeColumnName, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=手动}" Content="手动" Foreground="White" Margin="0,0,8,0" />
                                                <CheckBox Click="ChangeTimeSyncMode_Click" IsChecked="{Binding CommandTypeColumnName, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=NTP对时}" Content="NTP对时" Foreground="White" Margin="8" />
                                                <CheckBox Click="ChangeTimeSyncMode_Click" IsChecked="{Binding CommandTypeColumnName, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=射频对时}" Content="射频对时" Foreground="White" Margin="8" />
                                                <CheckBox Click="ChangeTimeSyncMode_Click" IsChecked="{Binding CommandTypeColumnName, Mode=OneWay, Converter={StaticResource IsEditingValueConverter}, ConverterParameter=GPS}" Content="GPS" Foreground="White" Margin="8" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Margin="0,13" Foreground="White" HorizontalAlignment="Left" Opacity="0.6" FontSize="14" TextWrapping="Wrap" Width="480" Text="{Binding CommandTypeDesciption}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,43,0,0">
                                            <Button x:Name="btnTimeSyncConfirm" Click="btnTimeSyncConfirm_Click" Background="#30479C" Foreground="White" BorderThickness="0" Content="应用" />
                                            <Button x:Name="btnTimeSyncReset" Click="btnTimeSyncReset_Click" Margin="32,0,0,0" Background="Transparent" BorderThickness="1"  BorderBrush="#404870" Foreground="White" Content="重置"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1" Visibility="{Binding CommandType, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Brightness;Volume;Restart}">
                            <StackPanel>
                                <TextBlock Margin="19,12"  VerticalAlignment="Center" FontSize="20" Foreground="White" Text="定时控制"></TextBlock>
                                <StackPanel >
                                    <StackPanel Orientation="Horizontal" Margin="19,12,0,12">
                                        <Image Cursor="Hand" x:Name="btnAddTimeControl" MouseDown="btnAddTimeControl_MouseDown" Width="32" Height="32" Source="/Assets/7.png" Margin="0,0,16,0" HorizontalAlignment="Left"/>
                                        <Image Width="32" Height="32" Source="/Assets/8.png" Margin="0,0,16,0" Cursor="Hand" HorizontalAlignment="Left"/>
                                        <Image x:Name="btnDeleteTimeControl" MouseDown="btnDeleteTimeControl_MouseDown"  Width="32" Height="32" Source="/Assets/9.png" Margin="0,0,16,0" Cursor="Hand" HorizontalAlignment="Left" />
                                    </StackPanel>
                                    <Grid Margin="19,0">
                                        <Border Background="#1A1E30" Height="40" VerticalAlignment="Top" />
                                        <DataGrid
                                            x:Name="dgTimeControls"
                                            AutoGenerateColumns="false" 
                                            CanUserAddRows="False"  
                                            FontSize="14" 
                                            IsReadOnly="True" 
                                            SelectionMode="Single" 
                                            FrozenColumnCount="1" 
                                            Background="Transparent" 
                                            ItemsSource="{Binding DeviceTimeControls, UpdateSourceTrigger=PropertyChanged}"
                                        >
                                            <!--<DataGrid.Resources>
                                            <Style TargetType="DataGridCell">
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="LightBlue"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Resources>-->
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="选择" Width="60"
                                                    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"                                                                        
                                                    IsReadOnly="False"
                                                    CanUserSort="False"/>
                                                <DataGridTextColumn Width="1*" Binding="{Binding ExecuteTime}" Header="执行时间"  />
                                                <DataGridTextColumn Width="1*" Binding="{Binding ExecuteMethod}" Header="重复方式" />
                                                <DataGridTextColumn Width="1*" Binding="{Binding ValidPeriod}" Header="有效日期">
                                                    <!--<DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="ToolTip" Value="{Binding ValidPeriod}"/>
                                                        <Setter Property="ToolTip">
                                                            <Setter.Value>
                                                                <ToolTip>
                                                                    <TextBlock Text="{Binding ValidPeriod}" FontSize="14" Foreground="Black"/>
                                                                </ToolTip>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>-->
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="1*" Binding="{Binding StatusText}" Header="是否启用" />
                                                <DataGridTemplateColumn Header="操作"  Width="80" >
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <Button Content="执行" FontSize="12" Foreground="White" Click="btnPublish_Click" Height="24" Width="60" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

        </StackPanel>
    </materialDesign:DialogHost>    
</LocalCore:FrameControl>
