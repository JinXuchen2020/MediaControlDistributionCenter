<UserControl x:Class="MediaControlDistributionCenter.Views.MediaPublishDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:CustomControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
             xmlns:local="clr-namespace:MediaControlDistributionCenter.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Border BorderThickness="1" Background="#090A0E">
        <Grid Width="889" Height="600" Background="#090A0E" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Margin="20,12,0,12">
                <TextBlock VerticalAlignment="Center" FontSize="20" Foreground="White" Text="{DynamicResource LanguageKey_Code_Media_SelectDeviceDialogTitle}" />
            </StackPanel>

            <StackPanel Margin="0,10,0,0" HorizontalAlignment="Right">
                <Button Width="60" Height="38" HorizontalAlignment="Right"
                Background="#090A0E" Foreground="WhiteSmoke"
                BorderThickness="0"
                HorizontalContentAlignment="Center"
                materialDesign:ColorZoneAssist.Mode="Custom"
                materialDesign:ColorZoneAssist.Background="#090A0E"
                materialDesign:ButtonAssist.CornerRadius="5"
                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                Content="{materialDesign:PackIcon Size=20,Kind=Close}" ToolTip="{DynamicResource LanguageKey_Code_SystemExitTip}"/>
            </StackPanel>

            <Border Grid.Row="1" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>

            <Border Grid.Row="2" Margin="20,24,20,24" Height="400" BorderThickness="0,2,0,0" Background="#16171D">
                <Grid>
                    <Border Background="#1A1E30" Height="40" VerticalAlignment="Top" />
                    <DataGrid 
                    AutoGenerateColumns="False" 
                    CanUserAddRows="False"  
                    FontSize="14" 
                    IsReadOnly="True" 
                    SelectionMode="Single"
                    FrozenColumnCount="1" 
                    Background="Transparent" 
                    ItemsSource="{Binding Devices, UpdateSourceTrigger=PropertyChanged}"
                >
                        <DataGrid.Resources>
                            <CustomControls:BindingProxy x:Key="proxy" Data="{Binding}" />
                            <Style x:Key="LeftAlignedCheckBoxStyle" TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                            <Style x:Key="LeftAlignedTextBlockStyle" TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Width="60"
                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                            ElementStyle="{StaticResource LeftAlignedCheckBoxStyle}"
                            IsReadOnly="False"
                            CanUserSort="False">
                                <DataGridCheckBoxColumn.Header>
                                    <CheckBox Unchecked="SelectDevicesAll_Click" Checked="SelectDevicesAll_Click" />
                                </DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Name}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_100}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding StatusText}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_101}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Resolution}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_102}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding MediaNames}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_103}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding SNumber}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_104}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="1*" ElementStyle="{StaticResource LeftAlignedTextBlockStyle}" Binding="{Binding Group}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource LanguageKey_Code_Monitor_Tooltip_105}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="3" Width="auto" Grid.ColumnSpan="2" Background="#40476F"/>
            <Grid Grid.Row="4">
                <StackPanel VerticalAlignment="Center" Margin="20,12,0,12" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock  FontSize="16" Text="{DynamicResource LanguageKey_Code_Program_Tooltip_100}" />
                    <TextBlock  FontSize="16" Margin="10,0,0,0" Text="{Binding CurrentMedia.Name}" />
                    <!--<CheckBox Margin="30,0,0,0" FontSize="14" VerticalAlignment="Center" Content="{DynamicResource LanguageKey_Code_Program_Tooltip_114}" IsChecked="{Binding IsCover, Converter={StaticResource IsEditingValueConverter}}" />-->
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnPublishSave" DockPanel.Dock="Left" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Media_Send}" Click="btnPublishSave_Click" />
                    <Button Margin="25" Background="#090A0E" Foreground="WhiteSmoke" Content="{DynamicResource LanguageKey_Code_Cancel}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
