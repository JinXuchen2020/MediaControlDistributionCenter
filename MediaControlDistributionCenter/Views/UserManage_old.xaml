<UserControl x:Class="MediaControlDistributionCenter.Views.UserManage_old"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MediaControlDistributionCenter.Views"
             xmlns:CustomControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!--<Setter Property="BorderThickness" Value="0"/>-->
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Border x:Name="mainBorder">
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
            </Grid>
            <Grid Grid.Row="1" Margin="0,10,0,10">
                <StackPanel Orientation="Horizontal">
                    <CustomControls:RoundRectButton
                      IconSource="\Assets\user_control.png"
                      CornerRadius="5"
                      Margin="5,0,0,0"
                      BorderWidth="0"
                      Background="#E1E1E1"
                      FontSize="16"
                      Width="100"
                      Height="50"
                      Click="RoundRectButton_Click"
                      IconVisibility="Collapsed"
                      Content="会员登记"/>
                    <CustomControls:RoundRectButton
                      IconSource="\Assets\user_control.png"
                      CornerRadius="5"
                      Margin="15,0,0,0"
                      BorderWidth="0"
                      Background="#E1E1E1"
                      FontSize="16"
                      Width="100"
                      Height="50"
                      IconVisibility="Collapsed"
                      Content="变更组"/>
                    <CustomControls:RoundRectButton
                      IconSource="\Assets\user_control.png"
                      CornerRadius="5"
                      Margin="15,0,0,0"
                      BorderWidth="0"
                      Background="#E1E1E1"
                      FontSize="16"
                      Width="100"
                      Height="50"
                      IconVisibility="Collapsed"
                      Content="播控盒登记"/>
                    <CustomControls:RoundRectButton
                      IconSource="\Assets\user_control.png"
                      CornerRadius="5"
                      Margin="15,0,60,0"
                      BorderWidth="0"
                      FontSize="16"
                      Background="#E1E1E1"
                      Width="100"
                      Height="50"
                      IconVisibility="Collapsed"
                      Content="删除"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="400" VerticalContentAlignment="Center" FontSize="18" Height="50"/>
                        <CustomControls:RoundRectButton
                          IconSource="\Assets\user_control.png"
                          CornerRadius="0"
                          BorderWidth="0"
                          FontSize="16"
                          Background="White"
                          Width="100"
                          Height="50"
                          IconVisibility="Collapsed"
                          Content="搜索"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="2">
                <DataGrid ItemsSource="{Binding Users}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      Background="White"
                      IsReadOnly="True" 
                      RowStyle="{StaticResource GridRowStyle}"
                      MinColumnWidth="100">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="LightGray"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="Height" Value="60"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="Auto" CanUserSort="False" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="操作" CanUserSort="False" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <CustomControls:RoundRectButton
                                         IconSource="\Assets\user_control.png"
                                         CornerRadius="5"
                                         BorderWidth="0"
                                         PressedColor="#E1E1E1"
                                         Padding="5"
                                         IconVisibility="Visible"
                                         Content="控制"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="功能" Binding="{Binding Function}" CanUserSort="False" />
                        <DataGridTextColumn Header="权限" Binding="{Binding Permission}" SortMemberPath="Permission" />
                        <DataGridTextColumn Header="组" Binding="{Binding Group}" SortMemberPath="Group" />
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" SortMemberPath="ID" />
                        <DataGridTextColumn Header="公司名称" Binding="{Binding CompanyName}" CanUserSort="False"  />
                        <DataGridTextColumn Header="地区" Binding="{Binding Region}" CanUserSort="False" />
                        <DataGridTemplateColumn Header="编辑" CanUserSort="False" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <CustomControls:RoundRectButton
                                          CornerRadius="5"
                                          BorderWidth="0"
                                          IconVisibility="Collapsed"
                                          PressedColor="#E1E1E1"
                                          Padding="10"
                                          Click="UserEditButton_Click"
                                          Content="编辑"/>
                                        <TextBlock Text="|" VerticalAlignment="Center" Margin="5,0"/>
                                        <CustomControls:RoundRectButton
                                          CornerRadius="5"
                                          BorderWidth="0"
                                          IconVisibility="Collapsed"
                                          PressedColor="#E1E1E1"
                                          Padding="10"
                                          Content="删除"/>
                                        <TextBlock Text="|" VerticalAlignment="Center" Margin="5,0"/>
                                        <CustomControls:RoundRectButton
                                          CornerRadius="5"
                                          BorderWidth="0"
                                          IconVisibility="Collapsed"
                                          PressedColor="#E1E1E1"
                                          Padding="10"
                                          Content="LOG"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
