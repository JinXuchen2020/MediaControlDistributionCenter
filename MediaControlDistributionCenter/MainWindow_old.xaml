<Window x:Class="MediaControlDistributionCenter.MainWindow_old"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaControlDistributionCenter"
        xmlns:CustomControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
        xmlns:views="clr-namespace:MediaControlDistributionCenter.Views"
        WindowState="Maximized"
        WindowStyle="ThreeDBorderWindow"
        ResizeMode="CanMinimize"
        mc:Ignorable="d"
        Title="MainWindow">
    <Window.Resources>

        <Style TargetType="Button" x:Key="lanButton">
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
       
    </Window.Resources>
    <Grid>
        <!-- 定义行 -->
        <Grid.RowDefinitions>
            <!-- 上栏，固定高度 -->
            <RowDefinition Height="60" />
            <!-- 这里设置为 100 高度 -->
            <!-- 中间栏，自动调整 -->
            <RowDefinition Height="*" />
            <!-- 中间区域，动态调整 -->
            <!-- 下栏，固定高度 -->
            <RowDefinition Height="50" />
            <!-- 这里设置为 50 高度 -->
        </Grid.RowDefinitions>

        <!-- 上栏内容 -->
        <Border Background="LightBlue" Grid.Row="0">
            <Grid x:Name="top" Grid.Row="0">
                <Border Background="#545454"/>
                <StackPanel Orientation="Horizontal">
                    <CustomControls:CheckButton
                          CornerRadius="5"
                          Content="仪表盘"
                          FontSize="16"
                          Width="100" Height="50"
                          Checked="CheckButton_Checked"
                          Unchecked="CheckButton_Unchecked"
                          Foreground="White"/>
                    <CustomControls:CheckButton
                          CornerRadius="5"
                          Content="设备管理"
                          FontSize="16"
                          Width="100" Height="50"
                          Checked="CheckButton_Checked"
                          Unchecked="CheckButton_Unchecked"
                          Foreground="White"/>
                    <CustomControls:CheckButton
                        x:Name="userManage"
                        CornerRadius="5"
                        Content="用户管理"
                        FontSize="16"
                        Width="100" Height="50"
                        Checked="CheckButton_Checked"
                        Unchecked="CheckButton_Unchecked"
                        Foreground="White"/>
                    <CustomControls:CheckButton
                        CornerRadius="5"
                        Content="模板库"
                        FontSize="16"
                        Width="100" Height="50"
                        Checked="CheckButton_Checked"
                        Unchecked="CheckButton_Unchecked"
                        Foreground="White"/>
                    <CustomControls:CheckButton
                        CornerRadius="5"
                        Content="设定"
                        FontSize="16"
                        Width="100" Height="50"
                        Checked="CheckButton_Checked"
                        Unchecked="CheckButton_Unchecked"
                        Foreground="White"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <CustomControls:RoundRectButton x:Name="LanguageButton" HorizontalAlignment="Right" 
                                                    Margin="0,0,5,0"
                                                    Background="WhiteSmoke" 
                                                    CornerRadius="2"
                                                    BorderWidth="0"
                                                    IconSource="/Assets/地球.png"
                                                    Width="150"
                                                    Height="50"
                                                    Click="LanguageButton_Click"
                                                    Content="{DynamicResource LanguageKey_Code_SwitchLanguage}" />

                    

                    <Popup x:Name="LanguagePopup" Placement="Bottom" StaysOpen="False" PlacementTarget="{Binding ElementName=LanguageButton}">
                        <StackPanel Background="WhiteSmoke" Width="150">
                            <Button x:Name="ChineseButton" Style="{StaticResource lanButton}" Content="中文" Click="ChangeLanguage"/>
                            <Button x:Name="EnglishButton" Style="{StaticResource lanButton}" Content="英语" Click="ChangeLanguage"/>
                            <Button x:Name="JapaneseButton" Style="{StaticResource lanButton}" Content="日语" Click="ChangeLanguage"/>
                            <Button x:Name="KoreanButton" Style="{StaticResource lanButton}" Content="韩语" Click="ChangeLanguage"/>
                        </StackPanel>
                    </Popup>
                    <CustomControls:RoundRectButton x:Name="logoutButton"
                                HorizontalAlignment="Right"
                                Margin="0,5"
                                CornerRadius="2"
                                BorderWidth="0"
                                Background="Transparent"
                                Foreground="WhiteSmoke" 
                                IconVisibility="Collapsed"
                                Width="100"
                                Height="50"
                                Click="logoutButton_Click"
                                Content="退出登录"
                                IconSource="/Assets/loginbutton.png"
                        />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 中间栏内容 -->
        <Border x:Name="borderMiddle" Background="Transparent" Grid.Row="1">
            <Grid x:Name="gridMiddle">
                 <!--定义两行两列--> 
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                     <!--第一行，占1/2的空间--> 
                    <RowDefinition Height="*" />
                     <!--第二行，占1/2的空间--> 
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                     <!--第一列，占1/2的空间--> 
                    <ColumnDefinition Width="*" />
                     <!--第二列，占1/2的空间--> 
                </Grid.ColumnDefinitions>

                 <!--上左卡片--> 
                <Grid Grid.Row="0" Grid.Column="0">
                    <Border  CornerRadius="10" Margin="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#EEEDFD" Offset="0" />
                                <GradientStop Color="#FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="上左" />
                    
                    </Border>

                    <Image Source="/Assets/1.png"/>
                </Grid>

                 <!--上右卡片--> 

                <Grid Grid.Row="0" Grid.Column="1"  >
                    <Border CornerRadius="10" Margin="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#EEEDFD" Offset="0" />
                                <GradientStop Color="#FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>


                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="上右" />
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="Quick Control" />
                </Grid>
                 <!--下左卡片--> 
                <Border Grid.Row="1" Grid.Column="0" CornerRadius="10" Margin="10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FEF8E7" Offset="0" />
                            <GradientStop Color="#FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <!--<TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="下左" />-->
                    <views:UserRegister></views:UserRegister>
                </Border>

                 <!--下右卡片--> 
                <Border Grid.Row="1" Grid.Column="1" CornerRadius="10" Margin="10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#E7F8F0" Offset="0" />
                            <GradientStop Color="#FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="下右" />
                </Border>

            </Grid>

        </Border>
        <Border x:Name="borderMiddleAdd" Background="Transparent" Grid.Row="1" Visibility="Collapsed"></Border>
        <Grid Grid.Row="2">
            <Border Background="#545454"/>
            <!-- 下栏内容 -->
            <Border Background="Transparent" Grid.Row="2" HorizontalAlignment="Left">
                <Grid>
                    <CustomControls:CircleWithTextControl Padding="2" Diameter="30" CircleColor="#92D050" Text="网络-正常连接" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                </Grid>
                <!--<TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20">Bottom Section</TextBlock>-->
            </Border>
        </Grid>
    </Grid>
</Window>
