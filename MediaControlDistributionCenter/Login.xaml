<Window x:Class="MediaControlDistributionCenter.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaControlDistributionCenter"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
        
        MouseDown="Window_MouseDown"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Title="{DynamicResource LanguageKey_Code_SystemTitle}" Height="1024" Width="1440">
    <Window.Resources>

    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Image Grid.ColumnSpan="2"
               Grid.RowSpan="2"
               Source="/Assets/assets-0001.png"
               Stretch="Fill" />
        <Grid Grid.ColumnSpan="2" Grid.Row="0" Margin="0,15,0,0" >
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <materialDesign:PopupBox StaysOpen="False" HorizontalAlignment="Center"
                   PlacementMode="BottomAndAlignCentres"
                   PopupMode="Click">
                    <materialDesign:PopupBox.ToggleContent>
                        <Border CornerRadius="2"
                           Padding="10"
                           Width="100"
                           BorderBrush="White"
                           BorderThickness="1">
                            <TextBlock x:Name="SysLanguage" HorizontalAlignment="Center" Text="{DynamicResource LanguageKey_Code_ZH}" Foreground="White"/>
                        </Border>
                    </materialDesign:PopupBox.ToggleContent>
                    <ListView Width="100">
                        <ListViewItem x:Name="zh_CN" Selected="LanguageSelectionChanged" Content="{DynamicResource LanguageKey_Code_ZH}"/>
                        <ListViewItem x:Name="en_US" Selected="LanguageSelectionChanged" Content="{DynamicResource LanguageKey_Code_EN}" />
                        <ListViewItem x:Name="ja_JP" Selected="LanguageSelectionChanged" Content="{DynamicResource LanguageKey_Code_JP}"/>
                        <ListViewItem x:Name="ko_KR" Selected="LanguageSelectionChanged" Content="{DynamicResource LanguageKey_Code_KO}"/>
                    </ListView>
                </materialDesign:PopupBox>
                <Button HorizontalAlignment="Left" Width="122" Height="34"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                        Click="ExitButton_Click"
                        ToolTip="{DynamicResource LanguageKey_Code_SystemExitTip}" Cursor="Hand">
                    <Image Source="/Assets/assets-0002.png"
                           Width="45"
                           Height="45"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="158,300,0,0"   HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel HorizontalAlignment="Center">
                <Image Source="/Assets/assets-0004.png"
                           Width="160"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <TextBlock Foreground="White"
                               Margin="0,31,0,0"
                               FontSize="52" 
                               FontWeight="Black"
                               VerticalAlignment="Center"
                               Text="{DynamicResource LanguageKey_Code_LoginDescription}"/>
                <StackPanel Orientation="Horizontal" Margin="0,31,0,0">
                    <Image Source="/Assets/assets-0003.png"
                           Width="20"
                           Height="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    <TextBlock Foreground="#A0A3A8" FontSize="20"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource LanguageKey_Code_SystemFeature1}"/>
                    <Image Source="/Assets/assets-0003.png"
                           Width="20"
                           Height="20"
                           Margin="10,0,0,0"
                           Opacity="5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    <TextBlock Foreground="#A0A3A8"  FontSize="20"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource LanguageKey_Code_SystemFeature2}"/>


                    <Image Source="/Assets/assets-0003.png"
                           Width="20"
                           Height="20"
                           Margin="10,0,0,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    <TextBlock Foreground="#A0A3A8"  FontSize="20"
                                   VerticalAlignment="Center" Text="{DynamicResource LanguageKey_Code_SystemFeature3}"/>


                </StackPanel>
            </StackPanel> 
        </Grid>

        
        
        <Label  Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="165,875,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"  
Content="{DynamicResource LanguageKey_Code_LoginSlogan}" Opacity="0.7"
/>
        <Grid Grid.Column="1" Grid.Row="1" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="6"
                    BorderThickness="1"
                    BorderBrush="#3C4B6D"
                    Background="#131A32"
                    CornerRadius="5" Width="551" Height="727" >
                <Grid>

                    <Label  Margin="113,145,0,0" VerticalAlignment="Top" FontSize="28" HorizontalAlignment="Left"
             Content="{DynamicResource LanguageKey_Code_LoginTitle}"
             />
                    <StackPanel Margin="0,265,0,0" VerticalAlignment="Top">
                        <TextBox x:Name="txtLoginId" BorderBrush="White"
                                 FontSize="18" Foreground="White" Width="300" Height="60" 
                                 materialDesign:HintAssist.Hint="{DynamicResource LanguageKey_Code_LoginAccount}"
                                 materialDesign:TextFieldAssist.UnderlineBrush="WhiteSmoke"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:TextFieldAssist.PrefixTextVisibility="WhenFocusedOrNonEmpty"
                                 materialDesign:TextFieldAssist.PrefixText=""/>
                        <PasswordBox x:Name="passwordBox"
                                     Margin="0,30,0,0"
                                     FontSize="18"
                                     Foreground="White"
                                     Width="300" Height="60"
                                     Style="{StaticResource MaterialDesignRevealPasswordBox}"
                                     materialDesign:TextFieldAssist.PrefixText=""
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     materialDesign:TextFieldAssist.PrefixTextVisibility="WhenFocusedOrNonEmpty"
                                     materialDesign:HintAssist.Hint="{DynamicResource LanguageKey_Code_LoginPassword}" />

                        <Button Content="{DynamicResource LanguageKey_Code_LoginBtn}" Margin="0,30,0,0"
          Width="325" Height="44"
          IsDefault="True" Background="#3B57BF" Foreground="White"
          IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
          Style="{StaticResource MaterialDesignPaperDarkButton}"
          materialDesign:ButtonAssist.CornerRadius="2"
          Click="btnLogin_Click"
          materialDesign:ThemeAssist.Theme="Light"/>


                    </StackPanel>


                    <Label  Margin="0,642,0,0" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="14"  
Content="{DynamicResource LanguageKey_Code_LoginSubTitle}" Opacity="0.7"
/>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
