{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Debug", "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      {
        "Name": "Debug"
      },
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/mcdc-log-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "Properties": {
      "Application": "MediaControlDistributionCenter"
    }
  },
  "ConnectionMode": {
    "ServiceUri": "" //http://1.255.226.145:12106
  },
  "FtpConnection": {
    "IpAddress": "", //http://47.102.47.221:9000
    "Port": 9938,
    "UserName": "admin",
    "UserPassword": "admin",
    "BasePath": ""
  },
  "SkiaCanvas": {
    "Enabled": false,
    "UseSkiaPreview": false,
    "UseSkiaEditor": false
  }
}
