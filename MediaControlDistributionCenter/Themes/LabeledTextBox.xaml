<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:customControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls">
    <Style TargetType="{x:Type customControls:LabeledTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type customControls:LabeledTextBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{TemplateBinding LabelText}" VerticalAlignment="Center" Margin="5" 
                               HorizontalAlignment="Stretch" VerticalContentAlignment="Center"/>
                        <Border Grid.Column="1" CornerRadius="{TemplateBinding CornerRadius}" 
                                VerticalAlignment="Stretch"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                Margin="5"
                                Background="White"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <TextBox VerticalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Padding="5" 
                                     Text="{TemplateBinding Text}" Background="Transparent" BorderThickness="0"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
