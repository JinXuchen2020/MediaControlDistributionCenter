<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:customControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls">
    <Style TargetType="{x:Type customControls:TimeTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type customControls:TimeTextBox}">
                    <TextBox x:Name="TimeTextBox"                        
                         Text="{Binding Text, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                         VerticalAlignment="Center" Padding="5" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" BorderBrush="#404870" BorderThickness="1"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>