<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:customControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
                    xmlns:converts="clr-namespace:MediaControlDistributionCenter.Converters"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:Class="MediaControlDistributionCenter.Views.CustomControls.IconTextBoxStyle">
    <converts:NotEmptyConverter x:Key="NotEmptyConverter"/>

    <Style TargetType="customControls:IconTextBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="customControls:IconTextBox">
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent},FallbackValue= 5}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 图标 -->
                            <Image Grid.Column="0" Source="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5" />


                            <!-- 输入框 -->
                            <TextBox x:Name="TextBoxControl"
                                     Grid.Column="1"
                                     VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                     BorderThickness="0"
                                     Margin="5,0"
                                     VerticalContentAlignment="Center" />

                            <!-- 密码框 -->
                            <PasswordBox x:Name="PasswordBoxControl"
                                         Grid.Column="1"
                                         VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                         BorderThickness="0"
                                         Margin="5,0"
                                         VerticalContentAlignment="Center"
                                         Visibility="Collapsed"/>
                            <!-- 水印提示 -->
                            <TextBlock x:Name="WatermarkText" Grid.Column="1"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Stretch"
                                       Text="{TemplateBinding Watermark}"
                                       Foreground="Gray"
                                       Margin="5,0"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>

                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
