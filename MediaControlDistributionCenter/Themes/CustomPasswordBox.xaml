<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:customControls="clr-namespace:MediaControlDistributionCenter.Views.CustomControls"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="{x:Type customControls:CustomPasswordBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type customControls:CustomPasswordBox}">
                    <Grid>
                        <Border Background="White" CornerRadius="{TemplateBinding CornerRadius}" BorderBrush="Gray" BorderThickness="1">
                            <Grid>
                                <TextBox x:Name="PART_TextBox" Margin="5,0,30,0" VerticalAlignment="Center" Visibility="Collapsed" BorderThickness="0"/>
                                <PasswordBox x:Name="PART_PasswordBox" Margin="5,0,30,0" VerticalAlignment="Center" BorderThickness="0"/>
                                <Image x:Name="PART_Icon" Source="{TemplateBinding Icon}" Width="{TemplateBinding Height}" Height="{TemplateBinding Height}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>